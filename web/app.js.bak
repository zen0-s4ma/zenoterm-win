let runtimeConfig = null;
let authStatus = { authenticated: false };
let tabs = [];
let activeTabId = null;
let selectedPresetIndex = 0;
let selectedScriptIndex = 0;
let selectedConfigSessionId = 'general';
let didAutoOpenDefaultSessionTabs = false;
let tabContextMenu = null;
let terminalContextMenu = null;
let activeAccordionSection = 'new-tab';
let selectedDockerGroupId = '';
let dockerDraftGroup = null;
let selectedSchedulerTaskId = '';
let selectedSchedulerLogTabId = 'scheduler-system';
let schedulerLogLastSeq = 0;
let schedulerStatePollTimer = null;
let schedulerLogPollTimer = null;
let explorerState = { currentPath: '', entries: [], breadcrumbs: [], filter: '', selectedPath: '', clipboard: null, openedFile: null, renderedMode: 'source', permission: { access: 'read_only', can_write: false } };
let explorerContextMenu = null;
let selectedAdminUserId = '';

const uid = (prefix = 'tab') => `${prefix}-${Math.random().toString(36).slice(2, 10)}`;
const getActiveTab = () => tabs.find((tab) => tab.id === activeTabId) || null;
const getTargetById = (id) => runtimeConfig.targets.find((target) => target.id === id) || null;
const displayAliasGroup = (value) => normalizeAliasFolder(value || '') || 'default-group';

function ensureSchedulerStore() {
  if (!runtimeConfig) return;
  if (!runtimeConfig.scheduler_management || typeof runtimeConfig.scheduler_management !== 'object') runtimeConfig.scheduler_management = {};
  if (!Array.isArray(runtimeConfig.scheduler_management.tasks)) runtimeConfig.scheduler_management.tasks = [];
  if (!Array.isArray(runtimeConfig.scheduler_management.log_tabs)) runtimeConfig.scheduler_management.log_tabs = [];
  if (!runtimeConfig.scheduler_management.catalog || typeof runtimeConfig.scheduler_management.catalog !== 'object') runtimeConfig.scheduler_management.catalog = { sessions: [], targets_by_session: {}, script_options: [], docker_group_options: [], event_keys: [] };
  if (!runtimeConfig.scheduler_management.stats || typeof runtimeConfig.scheduler_management.stats !== 'object') runtimeConfig.scheduler_management.stats = {};
}

function ensureDockerStore() {
  if (!runtimeConfig) return;
  if (!runtimeConfig.docker_management || typeof runtimeConfig.docker_management !== 'object') runtimeConfig.docker_management = {};
  if (!Array.isArray(runtimeConfig.docker_management.containers)) runtimeConfig.docker_management.containers = [];
  if (!Array.isArray(runtimeConfig.docker_management.groups)) runtimeConfig.docker_management.groups = [];
  if (!Array.isArray(runtimeConfig.docker_management.targets)) runtimeConfig.docker_management.targets = [];
  if (!runtimeConfig.docker_management.engine || typeof runtimeConfig.docker_management.engine !== 'object') runtimeConfig.docker_management.engine = {};
}

function dockerContainers() {
  ensureDockerStore();
  return runtimeConfig?.docker_management?.containers || [];
}

function dockerGroups() {
  ensureDockerStore();
  return runtimeConfig?.docker_management?.groups || [];
}

function newEmptyDockerGroup() {
  return { id: uid('docker-group'), name: '', description: '', default_run_mode: 'normal', entries: [], script_name: '' };
}

function schedulerTasks() {
  ensureSchedulerStore();
  return runtimeConfig?.scheduler_management?.tasks || [];
}

function schedulerCatalog() {
  ensureSchedulerStore();
  return runtimeConfig?.scheduler_management?.catalog || { sessions: [], targets_by_session: {}, script_options: [], docker_group_options: [], event_keys: [] };
}

function schedulerLogTabs() {
  ensureSchedulerStore();
  return runtimeConfig?.scheduler_management?.log_tabs || [];
}

function schedulerStats() {
  ensureSchedulerStore();
  return runtimeConfig?.scheduler_management?.stats || {};
}

function newEmptySchedulerTask() {
  const firstSession = schedulerCatalog().sessions?.[0]?.id || runtimeConfig?.active_session_id || 'default';
  const firstTarget = (schedulerCatalog().targets_by_session?.[firstSession] || [])[0];
  const firstScript = schedulerCatalog().script_options?.[0];
  const firstDockerGroup = schedulerCatalog().docker_group_options?.[0];
  return {
    id: uid('scheduler-task'),
    name: 'Nueva tarea programada',
    enabled: true,
    category: 'General',
    subcategory: 'General',
    description: '',
    dispatch_scope: 'terminal',
    session_id: firstSession,
    target_ids: firstTarget ? [firstTarget.id] : [],
    launch_type: firstScript ? 'script' : 'command',
    command_text: '',
    script_id: firstScript?.id || '',
    docker_group_id: firstDockerGroup?.id || '',
    schedule_type: 'once',
    run_at: '',
    delay_minutes: 15,
    interval_minutes: 60,
    daily_time: '08:00',
    weekly_time: '08:00',
    weekly_days: [1],
    event_key: '',
    timeout_seconds: 0,
    allow_overlap: false,
    keep_log_tab_open: true,
    last_run_at: '',
    last_finished_at: '',
    last_status: 'idle',
    last_message: '',
    last_duration_seconds: 0,
    created_at: '',
    updated_at: '',
    schedule_anchor_at: '',
  };
}

function setSchedulerMessage(message = '') {
  if (els.schedulerMessage) els.schedulerMessage.textContent = message;
}

function currentSchedulerTask() {
  ensureSchedulerStore();
  const tasks = schedulerTasks();
  let current = tasks.find((item) => item.id === selectedSchedulerTaskId) || null;
  if (!current && tasks.length) {
    current = tasks[0];
    selectedSchedulerTaskId = current.id;
  }
  if (!current) {
    current = newEmptySchedulerTask();
    runtimeConfig.scheduler_management.tasks = [current];
    selectedSchedulerTaskId = current.id;
  }
  return current;
}


function setDockerMessage(message = '') {
  if (els.dockerMessage) els.dockerMessage.textContent = message;
}

async function refreshDockerOverview(options = {}) {
  const silent = !!options.silent;
  try {
    const response = await fetchJson('/api/docker/overview');
    runtimeConfig = response.config;
    ensureScriptsArray();
    ensureDockerStore();
    if (!silent) setDockerMessage('Inventario Docker actualizado.');
    populateTopSessionSelectors();
    updateNewTabTargetOptions();
    syncNewTabNameWithTarget(true);
    renderNewTabCredentialFields();
    renderScriptsPanel();
    if (!els.dockerView?.classList.contains('hidden')) renderDockerManagement();
    return response;
  } catch (error) {
    if (!silent) setDockerMessage(error.message || 'No se pudo actualizar Docker.');
    throw error;
  }
}


function targetOsOptions() {
  return runtimeConfig?.supported_target_oses || [];
}

function defaultTargetOsForScope(scope = 'local') {
  if (scope === 'local' || scope === 'docker') return runtimeConfig?.host_os || 'windows';
  return els.newTabTargetOsSelect?.value || runtimeConfig?.host_os || 'linux';
}

function shellItemsFor(scope, targetOs) {
  if (!runtimeConfig) return [];
  if (scope === 'local') return runtimeConfig.local_shells_by_os?.[targetOs] || [];
  return runtimeConfig.shell_catalog?.[targetOs] || [];
}

function shellOptionsFor(scope, targetOs) {
  return shellItemsFor(scope, targetOs).map((item) => `<option value="${escapeHtml(item.id)}">${escapeHtml(item.label)}</option>`).join('');
}

function firstShellIdFor(scope, targetOs) {
  return shellItemsFor(scope, targetOs)[0]?.id || '';
}

function ensurePresetShellSelection(preset) {
  if (!preset) return;
  if (!preset.target_os) preset.target_os = defaultTargetOsForScope(preset.scope || 'local');
  if (preset.scope === 'local' && preset.target_os !== (runtimeConfig?.host_os || preset.target_os)) {
    preset.target_os = runtimeConfig?.host_os || preset.target_os;
  }
  const validShells = shellItemsFor(preset.scope || 'local', preset.target_os);
  const validIds = new Set(validShells.map((item) => item.id));
  if (!validIds.has(preset.shell_family)) {
    preset.shell_family = validShells[0]?.id || '';
  }
  if (!preset.launch_command) preset.launch_command = preset.shell_family || '';
}

const supportsAliases = (target) => !!target?.shell_family;
const historyLimit = () => Math.max(1, Number(runtimeConfig?.ui?.command_history_limit || 50));

function pushCommandHistory(tab, rawCommand) {
  const command = String(rawCommand || '').trim();
  if (!tab || !command) return;
  if (!Array.isArray(tab.commandHistory)) tab.commandHistory = [];
  tab.commandHistory.unshift({ command, timestamp: new Date().toISOString() });
  tab.commandHistory = tab.commandHistory.slice(0, historyLimit());
  if (tab.id === activeTabId) renderCommandHistory();
}

function applyHistoryLimitToAllTabs() {
  const limit = historyLimit();
  tabs.forEach((tab) => {
    tab.commandHistory = (tab.commandHistory || []).slice(0, limit);
  });
  renderCommandHistory();
}

const metaKeyClass = (index) => `meta-key-${index % 7}`;

function normalizeCommandSource(preset) {
  if (preset.command_source === 'file' || preset.command_source === 'text') return preset.command_source;
  if (preset.command_file_content) return 'file';
  return 'text';
}

function escapeHtml(value) {
  return String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
}

function normalizeAliasFolder(value) {
  const normalized = String(value || '').trim().replace(/\\+/g, '/').replace(/\/+/g, '/').replace(/^\/|\/$/g, '');
  return normalized || 'default-group';
}

function sessionItems() {
  const sessions = Array.isArray(runtimeConfig?.terminal_sessions) ? runtimeConfig.terminal_sessions : [];
  if (sessions.some((item) => item.id === 'default')) return sessions;
  return [{ id: 'default', name: 'Sesión principal' }, ...sessions];
}

function activeSessionId() {
  return runtimeConfig?.active_session_id || 'default';
}

function ensureSessionOverrideStore(sessionId) {
  if (!runtimeConfig.session_terminal_overrides || typeof runtimeConfig.session_terminal_overrides !== 'object') runtimeConfig.session_terminal_overrides = {};
  if (!runtimeConfig.session_terminal_overrides[sessionId] || typeof runtimeConfig.session_terminal_overrides[sessionId] !== 'object') runtimeConfig.session_terminal_overrides[sessionId] = {};
  return runtimeConfig.session_terminal_overrides[sessionId];
}

function getSessionPresetView(preset, sessionId = selectedConfigSessionId) {
  if (!preset) return null;
  if (!sessionId || sessionId === 'general') return { ...preset };
  const override = runtimeConfig?.session_terminal_overrides?.[sessionId]?.[preset.id] || {};
  return { ...preset, ...override, id: preset.id, detected_local: !!preset.detected_local, editable_scope: preset.editable_scope, editable_target_os: preset.editable_target_os, editable_remove: preset.editable_remove };
}

function updatePresetField(index, field, value) {
  const basePreset = runtimeConfig?.terminal_presets?.[index];
  if (!basePreset) return;
  if (!selectedConfigSessionId || selectedConfigSessionId === 'general') {
    basePreset[field] = value;
    return;
  }
  const store = ensureSessionOverrideStore(selectedConfigSessionId);
  const next = { ...(store[basePreset.id] || {}) };
  next[field] = value;
  store[basePreset.id] = next;
}

function clearPresetOverrideForCurrentSession(presetId) {
  if (!selectedConfigSessionId || selectedConfigSessionId === 'general') return;
  const store = ensureSessionOverrideStore(selectedConfigSessionId);
  delete store[presetId];
}

function emptyScriptTemplate() {
  return {
    id: uid('script'),
    name: `Script ${((runtimeConfig?.app_scripts || []).length || 0) + 1}`,
    category: 'General',
    subcategory: 'General',
    include_all_targets: true,
    target_ids: [],
    variants: {
      default: { enabled: true, path: '', command: '', args: '' },
      powershell: { enabled: false, path: '', command: '', args: '' },
      cmd: { enabled: false, path: '', command: '', args: '' },
      posix: { enabled: false, path: '', command: '', args: '' },
      generic: { enabled: false, path: '', command: '', args: '' },
    },
  };
}

function ensureScriptsArray() {
  if (!Array.isArray(runtimeConfig.app_scripts)) runtimeConfig.app_scripts = [];
  runtimeConfig.app_scripts.forEach((script) => {
    if (!script.variants || typeof script.variants !== 'object') script.variants = {};
    ['default', 'powershell', 'cmd', 'posix', 'generic'].forEach((key) => {
      const variant = script.variants[key] || {};
      script.variants[key] = {
        enabled: !!variant.enabled || !!variant.path || !!variant.command || !!variant.args,
        path: variant.path || '',
        command: variant.command || '',
        args: variant.args || '',
      };
    });
    if (!Array.isArray(script.target_ids)) script.target_ids = [];
    script.include_all_targets = script.include_all_targets !== false || !script.target_ids.length;
    script.category = script.category || 'General';
    script.subcategory = script.subcategory || 'General';
    script.source_path = script.source_path || '';
    script.auto_discovered = !!script.auto_discovered;
  });
}

function currentTargetOptions() {
  return Array.isArray(runtimeConfig?.targets) ? runtimeConfig.targets : [];
}

function availableScriptCategories(items = runtimeConfig?.app_scripts || []) {
  return [...new Set((items || []).map((item) => String(item.category || 'General')).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'es', { sensitivity: 'base' }));
}

function availableScriptSubcategories(items = runtimeConfig?.app_scripts || [], category = '') {
  const filtered = category ? items.filter((item) => String(item.category || '') === category) : items;
  return [...new Set((filtered || []).map((item) => String(item.subcategory || 'General')).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'es', { sensitivity: 'base' }));
}

function populateScriptConfigCategorySelector() {
  ensureScriptsArray();
  if (!els.scriptConfigCategorySelect) return;
  const categories = availableScriptCategories(runtimeConfig.app_scripts || []);
  const currentCategory = els.scriptConfigCategorySelect.value || '';
  els.scriptConfigCategorySelect.innerHTML = `<option value="">Todas las categorías</option>${categories.map((item) => `<option value="${escapeHtml(item)}" ${item === currentCategory ? 'selected' : ''}>${escapeHtml(item)}</option>`).join('')}`;
  if (currentCategory && !categories.includes(currentCategory)) {
    els.scriptConfigCategorySelect.value = '';
  }
}


function scriptMatchesTarget(script, target) {
  if (!script || !target) return false;
  if (script.include_all_targets) return true;
  return (script.target_ids || []).includes(target.id);
}

function visibleScriptsForActiveTab() {
  const tab = getActiveTab();
  const target = tab ? getTargetById(tab.targetId) : null;
  if (!tab || !target) return [];
  ensureScriptsArray();
  const category = els.scriptCategoryFilterSelect?.value || '';
  const subcategory = els.scriptSubcategoryFilterSelect?.value || '';
  return (runtimeConfig.app_scripts || []).filter((script) => {
    if (!scriptMatchesTarget(script, target)) return false;
    if (category && String(script.category || '') !== category) return false;
    if (subcategory && String(script.subcategory || '') !== subcategory) return false;
    return true;
  });
}

function resolveScriptVariantForTarget(script, target) {
  const variantKey = String(target?.alias_support || 'generic');
  const candidate = script?.variants?.[variantKey];
  if (candidate?.enabled && (candidate.command || candidate.args || candidate.path)) return candidate;
  return script?.variants?.default || { enabled: true, path: '', command: '', args: '' };
}

function shellCommandForTarget(target, variant) {
  const pathValue = String(variant?.path || '').trim();
  const commandValue = String(variant?.command || '').trim();
  const argsValue = String(variant?.args || '').trim();
  const fullCommand = [commandValue, argsValue].filter(Boolean).join(' ').trim();
  if (!pathValue && !fullCommand) return '';
  const family = String(target?.shell_family || '').toLowerCase();
  const os = String(target?.target_os || runtimeConfig?.host_os || '').toLowerCase();
  if (family === 'pwsh' || family === 'powershell') {
    if (pathValue && fullCommand) return `Set-Location -LiteralPath "${pathValue.replace(/"/g, '`"')}"; ${fullCommand}`;
    if (pathValue) return `Set-Location -LiteralPath "${pathValue.replace(/"/g, '`"')}"`;
    return fullCommand;
  }
  if (family === 'cmd' || os === 'windows') {
    if (pathValue && fullCommand) return `cd /d "${pathValue}" && ${fullCommand}`;
    if (pathValue) return `cd /d "${pathValue}"`;
    return fullCommand;
  }
  const safePath = pathValue.replace(/"/g, '\"');
  if (pathValue && fullCommand) return `cd "${safePath}" && ${fullCommand}`;
  if (pathValue) return `cd "${safePath}"`;
  return fullCommand;
}

function populateTopSessionSelectors() {
  const sessions = sessionItems();
  const active = activeSessionId();
  const options = sessions.map((item) => `<option value="${escapeHtml(item.id)}" ${item.id === active ? 'selected' : ''}>${escapeHtml(item.name)}</option>`).join('');
  if (els.activeSessionSelect) els.activeSessionSelect.innerHTML = options;
  if (els.configActiveSessionSelect) els.configActiveSessionSelect.innerHTML = options;
  const presetOptions = ['<option value="general">General</option>', ...sessions.map((item) => `<option value="${escapeHtml(item.id)}">Sesión: ${escapeHtml(item.name)}</option>`)].join('');
  if (els.configPresetSessionSelect) {
    els.configPresetSessionSelect.innerHTML = presetOptions;
    if (![...els.configPresetSessionSelect.options].some((opt) => opt.value === selectedConfigSessionId)) selectedConfigSessionId = 'general';
    els.configPresetSessionSelect.value = selectedConfigSessionId;
  }
}

function syncAccordionButtonState(section) {
  const toggle = section.querySelector('[data-accordion-toggle]');
  if (toggle) toggle.setAttribute('aria-expanded', section.classList.contains('expanded') ? 'true' : 'false');
}

function initializeAccordionState(defaultSectionName = 'new-tab') {
  document.querySelectorAll('[data-accordion-section]').forEach((section) => {
    const shouldBeExpanded = section.dataset.accordionSection === defaultSectionName || section.classList.contains('expanded');
    section.classList.toggle('expanded', shouldBeExpanded);
    syncAccordionButtonState(section);
  });
}

function bindAccordionEvents() {
  document.querySelectorAll('[data-accordion-toggle]').forEach((button) => {
    if (button.dataset.boundAccordion === '1') return;
    button.dataset.boundAccordion = '1';
    button.addEventListener('click', () => {
      const section = button.closest('[data-accordion-section]');
      if (!section) return;
      section.classList.toggle('expanded');
      syncAccordionButtonState(section);
    });
  });
  initializeAccordionState();
}


function ensureAuthenticatedUi() {
  const hidden = !(runtimeConfig?.auth?.login_required) || authStatus.authenticated;
  els.loginScreen.classList.toggle('hidden', hidden);
  applyFeatureVisibility();
}

async function fetchJson(url, options = {}) {
  const response = await fetch(url, {
    credentials: 'include',
    headers: { 'Content-Type': 'application/json', ...(options.headers || {}) },
    ...options,
  });
  let data = {};
  try { data = await response.json(); } catch {}
  if (!response.ok) throw new Error(data.message || data.error || `HTTP ${response.status}`);
  return data;
}

async function readFileAsText(file) {
  if (!file) return '';
  return await file.text();
}

function currentUser() { return runtimeConfig?.current_user || null; }
function currentPermissions() { return currentUser()?.permissions || {}; }
function currentAdministration() { return runtimeConfig?.administration || { enabled: false, roles: [], users: [] }; }
function userCan(permission) { return !!currentPermissions()[permission]; }
function allowedNewTabScopes() {
  const scopes = [];
  if (userCan('use_local_terminals')) scopes.push('local');
  if (userCan('use_remote_terminals')) scopes.push('remote');
  if (userCan('use_docker')) scopes.push('docker');
  return scopes;
}
function setAdminMessage(message = '') { if (els.adminMessage) els.adminMessage.textContent = message; }
function ensureAdministrationStore() {
  if (!runtimeConfig) return;
  if (!runtimeConfig.administration || typeof runtimeConfig.administration !== 'object') runtimeConfig.administration = { enabled: false, roles: [], users: [] };
  if (!Array.isArray(runtimeConfig.administration.roles)) runtimeConfig.administration.roles = [];
  if (!Array.isArray(runtimeConfig.administration.users)) runtimeConfig.administration.users = [];
}
function administrationUsers() { ensureAdministrationStore(); return runtimeConfig?.administration?.users || []; }
function administrationRoles() { ensureAdministrationStore(); return runtimeConfig?.administration?.roles || []; }
function selectedAdministrationUser() { return administrationUsers().find((item) => item.id === selectedAdminUserId) || administrationUsers()[0] || null; }
function newAdministrationUser() {
  return {
    id: uid('user'),
    username: '',
    display_name: 'Nuevo usuario',
    role: 'no_docker',
    enabled: true,
    explorer_entries: [{ path: runtimeConfig?.workspace_dir || '', label: 'Proyecto Zenoterm', access: 'read_only' }],
    new_password: 'user',
  };
}


function administrationRoleMeta(roleId) {
  return administrationRoles().find((item) => item.id === roleId) || administrationRoles()[0] || null;
}

function visibleViewName() {
  if (!els.mainView?.classList.contains('hidden')) return 'main';
  if (!els.configView?.classList.contains('hidden')) return 'config';
  if (!els.adminView?.classList.contains('hidden')) return 'administration';
  if (!els.scriptsView?.classList.contains('hidden')) return 'scripts';
  if (!els.dockerView?.classList.contains('hidden')) return 'docker';
  if (!els.schedulerView?.classList.contains('hidden')) return 'scheduler';
  if (!els.explorerView?.classList.contains('hidden')) return 'explorer';
  return 'main';
}

function absorbRuntimeConfig(config) {
  runtimeConfig = config || {};
  ensureScriptsArray();
  ensureDockerStore();
  ensureSchedulerStore();
  ensureAdministrationStore();
  if (selectedAdminUserId && !administrationUsers().some((item) => item.id === selectedAdminUserId)) selectedAdminUserId = '';
  if (!selectedAdminUserId && administrationUsers().length) selectedAdminUserId = administrationUsers()[0].id;
}

async function reloadRuntimeConfig() {
  absorbRuntimeConfig(await fetchJson('/api/config'));
  authStatus = await fetchJson('/api/auth/status');
  if (authStatus?.current_user) runtimeConfig.current_user = authStatus.current_user;
  setTopSubtitle();
  populateTopSessionSelectors();
  updateNewTabTargetOptions();
  renderNewTabCredentialFields();
  populateConfigView();
  renderScriptEditor();
  renderScriptsPanel();
  renderDockerManagement();
  renderTerminalMeta();
  updateExplorerClipboardInfo();
  renderExplorerPreview();
  renderAdministration();
  applyFeatureVisibility();
}

function applyFeatureVisibility() {
  const authenticated = !!(authStatus?.authenticated || !(runtimeConfig?.auth?.login_required));
  const view = visibleViewName();
  const onMain = view === 'main';
  const showWhenMain = (el, allowed) => { if (!el) return; el.classList.toggle('hidden', !(onMain && authenticated && allowed)); };
  showWhenMain(els.configBtn, userCan('manage_config'));
  showWhenMain(els.adminPageBtn, userCan('manage_administration'));
  showWhenMain(els.scriptsPageBtn, userCan('manage_scripts'));
  showWhenMain(els.dockerPageBtn, userCan('use_docker'));
  showWhenMain(els.schedulerPageBtn, userCan('manage_scheduler'));
  showWhenMain(els.explorerPageBtn, userCan('use_explorer'));
  if (els.backBtn) els.backBtn.classList.toggle('hidden', onMain || !authenticated);
  if (els.logoutBtn) els.logoutBtn.classList.toggle('hidden', !authenticated && !!runtimeConfig?.auth?.login_required);

  const scopes = authenticated ? allowedNewTabScopes() : [];
  const labels = { local: 'Local', remote: 'Remoto', docker: 'Docker' };
  if (els.newTabScopeSelect) {
    const previous = els.newTabScopeSelect.value;
    els.newTabScopeSelect.innerHTML = scopes.map((scope) => `<option value="${escapeHtml(scope)}">${escapeHtml(labels[scope] || scope)}</option>`).join('');
    if (scopes.includes(previous)) els.newTabScopeSelect.value = previous;
    else if (scopes.length) els.newTabScopeSelect.value = scopes[0];
    els.newTabScopeSelect.disabled = !scopes.length;
  }
  if (els.newTabBtn) els.newTabBtn.disabled = !authenticated || !scopes.length;
  if (!scopes.length) {
    if (els.newTabTargetOsSelect) els.newTabTargetOsSelect.innerHTML = '';
    if (els.newTabTargetSelect) els.newTabTargetSelect.innerHTML = '';
  }

  if (view === 'config' && !userCan('manage_config')) showMainView();
  if (view === 'administration' && !userCan('manage_administration')) showMainView();
  if (view === 'scripts' && !userCan('manage_scripts')) showMainView();
  if (view === 'docker' && !userCan('use_docker')) showMainView();
  if (view === 'scheduler' && !userCan('manage_scheduler')) showMainView();
  if (view === 'explorer' && !userCan('use_explorer')) showMainView();
}

function explorerCurrentPermission() {
  return explorerState.permission || { access: 'read_only', can_write: false };
}

function explorerCanWriteCurrentDir() {
  return !!explorerCurrentPermission().can_write;
}

function explorerCanWriteOpenedFile() {
  return !!(explorerState.openedFile?.permission?.can_write);
}

function applyExplorerPermissionUi() {
  if (els.explorerNewFolderBtn) els.explorerNewFolderBtn.disabled = !explorerCanWriteCurrentDir();
  if (els.explorerPasteBtn) els.explorerPasteBtn.disabled = !explorerCanWriteCurrentDir() || !explorerState.clipboard;
  if (els.explorerSaveFileBtn) els.explorerSaveFileBtn.disabled = !explorerCanWriteOpenedFile();
  if (els.explorerEditor) els.explorerEditor.readOnly = !explorerCanWriteOpenedFile();
  if (els.explorerDropZone) els.explorerDropZone.classList.toggle('is-disabled', !explorerCanWriteCurrentDir());
}

function renderAdministrationUsersList() {
  if (!els.adminUsersList) return;
  const users = administrationUsers();
  if (!users.length) {
    els.adminUsersList.innerHTML = '<div class="admin-empty-state">Todavía no hay usuarios en esta vista.</div>';
    return;
  }
  if (!selectedAdminUserId || !users.some((item) => item.id === selectedAdminUserId)) selectedAdminUserId = users[0].id;
  els.adminUsersList.innerHTML = users.map((user) => `
    <button type="button" class="admin-user-card ${user.id === selectedAdminUserId ? 'is-selected' : ''}" data-admin-user-id="${escapeHtml(user.id)}">
      <div class="admin-user-head">
        <div class="admin-user-title">
          <strong>${escapeHtml(user.display_name || user.username || 'Usuario')}</strong>
          <span class="admin-user-subline">${escapeHtml(user.username || 'sin-usuario')}</span>
        </div>
        <span class="admin-state-badge ${user.enabled ? 'is-enabled' : 'is-disabled'}">${user.enabled ? 'Activo' : 'Deshabilitado'}</span>
      </div>
      <div class="admin-user-badges">
        <span class="admin-role-badge">${escapeHtml(user.role_label || administrationRoleMeta(user.role)?.label || user.role || 'Perfil')}</span>
      </div>
    </button>
  `).join('');
  els.adminUsersList.querySelectorAll('[data-admin-user-id]').forEach((button) => {
    button.addEventListener('click', () => {
      selectedAdminUserId = button.dataset.adminUserId || '';
      renderAdministration();
    });
  });
}

function bindAdministrationEditorEvents() {
  if (!els.adminUserEditor) return;
  const user = selectedAdministrationUser();
  if (!user) return;

  els.adminUserEditor.querySelectorAll('[data-admin-field]').forEach((input) => {
    const applyValue = () => {
      const field = input.dataset.adminField || '';
      if (!field) return;
      user[field] = input.type === 'checkbox' ? !!input.checked : input.value;
      if (field === 'role') {
        const role = input.value || 'no_docker';
        user.role = role;
        const meta = administrationRoleMeta(role);
        user.role_label = meta?.label || role;
        if (role === 'administrator') user.explorer_entries = [];
        else if (!Array.isArray(user.explorer_entries) || !user.explorer_entries.length) user.explorer_entries = [{ path: runtimeConfig?.workspace_dir || '', label: 'Proyecto Zenoterm', access: 'read_only' }];
        renderAdministration();
        return;
      }
      if (field === 'display_name' || field === 'username' || field === 'enabled') renderAdministrationUsersList();
    };
    input.addEventListener(input.type === 'checkbox' || input.tagName === 'SELECT' ? 'change' : 'input', applyValue);
  });

  els.adminUserEditor.querySelectorAll('[data-admin-add-entry]').forEach((button) => {
    button.addEventListener('click', () => {
      if (!Array.isArray(user.explorer_entries)) user.explorer_entries = [];
      user.explorer_entries.push({ path: runtimeConfig?.workspace_dir || '', label: 'Nueva ruta', access: 'read_only' });
      renderAdministration();
    });
  });

  els.adminUserEditor.querySelectorAll('[data-admin-remove-entry]').forEach((button) => {
    button.addEventListener('click', () => {
      const index = Number(button.dataset.adminRemoveEntry || -1);
      if (!Array.isArray(user.explorer_entries)) user.explorer_entries = [];
      user.explorer_entries = user.explorer_entries.filter((_, entryIndex) => entryIndex !== index);
      renderAdministration();
    });
  });

  els.adminUserEditor.querySelectorAll('[data-admin-entry-index]').forEach((input) => {
    const applyValue = () => {
      const index = Number(input.dataset.adminEntryIndex || -1);
      const field = input.dataset.adminEntryField || '';
      if (index < 0 || !field) return;
      if (!Array.isArray(user.explorer_entries)) user.explorer_entries = [];
      if (!user.explorer_entries[index]) user.explorer_entries[index] = { path: '', label: '', access: 'read_only' };
      user.explorer_entries[index][field] = input.type === 'checkbox' ? !!input.checked : input.value;
    };
    input.addEventListener(input.tagName === 'SELECT' ? 'change' : 'input', applyValue);
  });
}

function renderAdministrationEditor() {
  if (!els.adminUserEditor) return;
  const user = selectedAdministrationUser();
  if (!user) {
    els.adminUserEditor.innerHTML = '<div class="admin-empty-state">Selecciona o crea un usuario para editarlo.</div>';
    return;
  }
  const roleMeta = administrationRoleMeta(user.role);
  const permissionTags = roleMeta ? [
    roleMeta.permissions?.manage_administration ? 'Administración' : null,
    roleMeta.permissions?.manage_config ? 'Config' : null,
    roleMeta.permissions?.manage_scripts ? 'Scripts' : null,
    roleMeta.permissions?.manage_scheduler ? 'Scheduler' : null,
    roleMeta.permissions?.use_local_terminals ? 'Terminal local' : null,
    roleMeta.permissions?.use_remote_terminals ? 'Terminal remota' : null,
    roleMeta.permissions?.use_docker ? 'Docker' : null,
  ].filter(Boolean) : [];
  const roleOptions = administrationRoles().map((role) => `<option value="${escapeHtml(role.id)}" ${role.id === user.role ? 'selected' : ''}>${escapeHtml(role.label || role.id)}</option>`).join('');
  const explorerSection = user.role === 'administrator'
    ? '<div class="admin-empty-state">El administrador tiene acceso total al Explorer y no necesita rutas específicas.</div>'
    : `
      <div class="admin-explorer-shell">
        <div class="admin-explorer-head">
          <h3>Explorer visible para este usuario</h3>
          <button type="button" class="config-action-btn" data-admin-add-entry>+ Añadir ruta</button>
        </div>
        <div class="credential-note">Define qué carpetas o ficheros puede ver y si son solo lectura o lectura/escritura.</div>
        <div class="admin-explorer-list">
          ${((Array.isArray(user.explorer_entries) ? user.explorer_entries : []).length ? user.explorer_entries : [{ path: runtimeConfig?.workspace_dir || '', label: 'Proyecto Zenoterm', access: 'read_only' }]).map((entry, index) => `
            <div class="admin-explorer-row">
              <label class="field"><span>Etiqueta</span><input type="text" data-admin-entry-index="${index}" data-admin-entry-field="label" value="${escapeHtml(entry.label || '')}" placeholder="Ej. Proyecto, Logs, Descargas"></label>
              <label class="field"><span>Ruta</span><input type="text" data-admin-entry-index="${index}" data-admin-entry-field="path" value="${escapeHtml(entry.path || '')}" placeholder="Ruta absoluta del host"></label>
              <label class="field"><span>Permiso</span><select data-admin-entry-index="${index}" data-admin-entry-field="access"><option value="read_only" ${entry.access === 'read_only' ? 'selected' : ''}>Solo consulta</option><option value="read_write" ${entry.access === 'read_write' ? 'selected' : ''}>Lectura / escritura</option></select></label>
              <button type="button" class="config-action-btn danger-btn" data-admin-remove-entry="${index}">Quitar</button>
            </div>
          `).join('')}
        </div>
      </div>`;

  els.adminUserEditor.innerHTML = `
    <div class="admin-editor-grid">
      <label class="field"><span>Usuario</span><input type="text" data-admin-field="username" value="${escapeHtml(user.username || '')}" placeholder="login"></label>
      <label class="field"><span>Nombre visible</span><input type="text" data-admin-field="display_name" value="${escapeHtml(user.display_name || '')}" placeholder="Nombre para mostrar"></label>
      <label class="field"><span>Perfil</span><select data-admin-field="role">${roleOptions}</select></label>
      <label class="field"><span>Nueva contraseña</span><input type="password" data-admin-field="new_password" value="${escapeHtml(user.new_password || '')}" placeholder="Vacío = mantener la actual"></label>
      <label class="check-field full-row"><input type="checkbox" data-admin-field="enabled" ${user.enabled ? 'checked' : ''}><span>Usuario habilitado</span></label>
    </div>
    <div>
      <h3>Permisos efectivos del perfil</h3>
      <div class="admin-permissions-grid">${permissionTags.map((tag) => `<span class="admin-permission-pill">${escapeHtml(tag)}</span>`).join('') || '<span class="admin-permission-pill">Sin permisos</span>'}</div>
    </div>
    ${explorerSection}
  `;
  bindAdministrationEditorEvents();
}

function renderAdministration() {
  ensureAdministrationStore();
  if (!els.adminView) return;
  if (!currentAdministration().enabled) {
    if (els.adminUsersList) els.adminUsersList.innerHTML = '<div class="admin-empty-state">Solo el administrador puede ver esta página.</div>';
    if (els.adminUserEditor) els.adminUserEditor.innerHTML = '<div class="admin-empty-state">Inicia sesión como administrador para gestionar usuarios, contraseñas y permisos.</div>';
    return;
  }
  renderAdministrationUsersList();
  renderAdministrationEditor();
}

function addAdministrationUser() {
  ensureAdministrationStore();
  const user = newAdministrationUser();
  runtimeConfig.administration.users = [...administrationUsers(), user];
  selectedAdminUserId = user.id;
  renderAdministration();
  setAdminMessage('Nuevo usuario preparado. Guarda para persistirlo.');
}

function removeAdministrationUser() {
  const user = selectedAdministrationUser();
  if (!user) return;
  if (!window.confirm(`¿Eliminar el usuario ${user.display_name || user.username}?`)) return;
  runtimeConfig.administration.users = administrationUsers().filter((item) => item.id !== user.id);
  selectedAdminUserId = administrationUsers()[0]?.id || '';
  renderAdministration();
  setAdminMessage('Usuario eliminado de la vista. Guarda para persistir.');
}

async function saveAdministrationUsers() {
  const response = await fetchJson('/api/administration/save', { method: 'POST', body: JSON.stringify({ users: administrationUsers() }) });
  absorbRuntimeConfig(response.config);
  authStatus.authenticated = true;
  authStatus.current_user = runtimeConfig.current_user;
  setTopSubtitle();
  populateTopSessionSelectors();
  updateNewTabTargetOptions();
  renderNewTabCredentialFields();
  populateConfigView();
  renderScriptEditor();
  renderScriptsPanel();
  renderDockerManagement();
  renderTerminalMeta();
  renderAdministration();
  applyFeatureVisibility();
  setAdminMessage('Usuarios y permisos guardados.');
  if (!userCan('manage_administration')) showMainView();
}

function showAdministrationView() {
  if (!userCan('manage_administration')) return;
  els.mainView.classList.add('hidden');
  els.configView.classList.add('hidden');
  els.adminView.classList.remove('hidden');
  els.scriptsView.classList.add('hidden');
  els.dockerView.classList.add('hidden');
  els.schedulerView.classList.add('hidden');
  els.explorerView.classList.add('hidden');
  stopSchedulerPolling();
  renderAdministration();
  applyFeatureVisibility();
}

function setTopSubtitle() {
  const base = 'Terminal web con tabs, alta automática al crear y configuración global separada.';
  const user = currentUser();
  els.appSubtitle.textContent = user ? `${base} · ${user.display_name || user.username} · ${user.role_label || user.role || 'Usuario'}` : base;
}

function populateNewTabTargetOsOptions() {
  const scope = els.newTabScopeSelect.value;
  const current = els.newTabTargetOsSelect.value || defaultTargetOsForScope(scope);
  const options = (scope === 'local' || scope === 'docker')
    ? [{ id: runtimeConfig.host_os, label: runtimeConfig.host_os_label || runtimeConfig.host_os }]
    : targetOsOptions();
  els.newTabTargetOsSelect.innerHTML = options.map((item) => {
    const selected = item.id === current ? 'selected' : '';
    return `<option value="${escapeHtml(item.id)}" ${selected}>${escapeHtml(item.label)}</option>`;
  }).join('');
  if (scope === 'local' || scope === 'docker') {
    els.newTabTargetOsSelect.value = runtimeConfig.host_os;
    els.newTabTargetOsSelect.disabled = true;
  } else {
    els.newTabTargetOsSelect.disabled = false;
  }
}

function getTargetsForNewTab() {
  const scope = els.newTabScopeSelect.value;
  const auth = els.newTabAuthSelect.value;
  const targetOs = els.newTabTargetOsSelect.value || defaultTargetOsForScope(scope);
  return runtimeConfig.targets.filter((target) => {
    if ((target.connection_scope || (target.mode === 'direct' ? 'local' : 'remote')) !== scope) return false;
    if (scope !== 'docker' && (target.target_os || runtimeConfig.host_os) !== targetOs) return false;
    if (scope === 'remote') return (target.auth_type || (target.mode === 'ssh_key' ? 'key' : 'password')) === auth;
    return true;
  });
}

function updateNewTabTargetOptions(selectedValue = '') {
  const allowedScopes = allowedNewTabScopes();
  if (!allowedScopes.length) {
    if (els.newTabTargetOsSelect) els.newTabTargetOsSelect.innerHTML = '';
    if (els.newTabTargetSelect) els.newTabTargetSelect.innerHTML = '';
    return;
  }
  if (!allowedScopes.includes(els.newTabScopeSelect.value)) els.newTabScopeSelect.value = allowedScopes[0];
  populateNewTabTargetOsOptions();
  const targets = getTargetsForNewTab();
  els.newTabTargetSelect.innerHTML = '';
  for (const target of targets) {
    const option = document.createElement('option');
    option.value = target.id;
    option.textContent = target.label;
    if ((selectedValue && target.id === selectedValue) || (!selectedValue && !els.newTabTargetSelect.children.length)) option.selected = true;
    els.newTabTargetSelect.appendChild(option);
  }
  syncNewTabNameWithTarget();
}

function suggestedNewTabName() {
  const target = getTargetById(els.newTabTargetSelect.value) || getTargetsForNewTab()[0] || null;
  return target?.label || '';
}

function syncNewTabNameWithTarget(force = false) {
  const suggested = suggestedNewTabName();
  if (!suggested) return;
  const previousAuto = els.newTabName.dataset.autoValue || '';
  const current = els.newTabName.value || '';
  if (force || !current.trim() || current === previousAuto) {
    els.newTabName.value = suggested;
    els.newTabName.dataset.autoValue = suggested;
  }
}

function detectCurrentPath(tab) {
  const text = extractTerminalText(tab);
  const lines = text.split(/\r?\n/).slice(-120).reverse();
  const patterns = [
    /^PS\s+(.+?)>\s*$/,
    /^(?:\([^\)]*\)\s*)?([A-Za-z]:\\[^>]*)>\s*$/,
    /^(?:[^\s@]+@[^\s:]+:)?(~?\/[^$#>]*)\s*[#$>]\s*$/,
    /^(?:[^\s@]+@[^\s:]+:)([^$#>]*)\s*[#$>]\s*$/,
  ];
  for (const rawLine of lines) {
    const line = rawLine.replace(/\x1b\[[0-9;?]*[A-Za-z]/g, '').trim();
    for (const pattern of patterns) {
      const match = line.match(pattern);
      if (match && match[1]) return match[1].trim();
    }
  }
  return tab.currentPath || 'Desconocido';
}

function targetSummary(target, tab) {
  if (!target || !tab) return [];
  const items = [
    { label: 'Nombre', value: tab.title },
    { label: 'Target Type', value: target.connection_scope === 'remote' ? 'Remote' : (target.connection_scope === 'docker' ? 'Docker' : 'Local') },
    { label: 'Target', value: target.shell_label || target.preset_name || target.label },
    { label: 'Estado', value: tab.lastStatus || 'Sin iniciar' },
    { label: 'Path', value: detectCurrentPath(tab) },
  ];
  if (target.connection_scope === 'remote') {
    items.push({ label: 'Host', value: tab.credentials.host || target.host || 'pendiente' });
    items.push({ label: 'Usuario', value: tab.credentials.username || target.username || 'pendiente' });
    items.push({ label: 'Auth', value: (target.auth_type || 'password') === 'key' ? 'Key' : 'User/Pass' });
  }
  if (target.connection_scope === 'docker') {
    items.push({ label: 'Container', value: target.docker_container_name || target.preset_name || target.label });
    items.push({ label: 'Image', value: target.docker_image || target.description || 'Docker' });
  }
  return items;
}

function renderTerminalMeta() {
  const tab = getActiveTab();
  const target = tab ? getTargetById(tab.targetId) : null;
  if (!tab || !target) {
    els.terminalMeta.innerHTML = '<span class="meta-item"><span class="meta-key meta-key-0">Estado:</span> Sin pestaña activa</span>';
    return;
  }
  const html = targetSummary(target, tab).map((item, index, arr) => {
    const chunk = `<span class="meta-item"><span class="meta-key ${metaKeyClass(index)}">${escapeHtml(item.label)}:</span> ${escapeHtml(item.value)}</span>`;
    return index < arr.length - 1 ? `${chunk}<span class="meta-separator"> - </span>` : chunk;
  }).join('');
  els.terminalMeta.innerHTML = html;
}

function renderCommandHistory() {
  const tab = getActiveTab();
  const items = tab?.commandHistory || [];
  if (!tab) {
    els.commandHistoryNote.textContent = 'Aquí verás los comandos detectados en esta pestaña.';
    els.commandHistoryList.innerHTML = '';
    return;
  }
  els.commandHistoryNote.textContent = `Máximo global actual: ${historyLimit()} comandos.`;
  if (!items.length) {
    els.commandHistoryList.innerHTML = '<div class="credential-note">Todavía no se han detectado comandos en esta pestaña.</div>';
    return;
  }
  els.commandHistoryList.innerHTML = items.map((item, index) => `
    <div class="simple-list-item">
      <strong>#${index + 1}</strong>
      <code>${escapeHtml(item.command)}</code>
      <span class="list-meta">${escapeHtml(new Date(item.timestamp).toLocaleString())}</span>
    </div>`).join('');
}

function renderAliasPanel() {
  const tab = getActiveTab();
  const target = tab ? getTargetById(tab.targetId) : null;
  const enabled = !!(tab && target && supportsAliases(target));
  els.aliasCreatorSection.classList.toggle('hidden', !enabled);
  els.aliasGroupFilterField?.classList.toggle('hidden', !enabled);
  if (!enabled) {
    els.aliasListNote.textContent = tab ? 'Esta pestaña no tiene tipo de terminal disponible para usar alias internos.' : 'Selecciona una pestaña para ver sus alias internos.';
    if (els.aliasGroupFilterSelect) els.aliasGroupFilterSelect.innerHTML = '<option value="">Todos los grupos</option>';
    els.aliasList.innerHTML = '';
    els.aliasMessage.textContent = '';
    return;
  }
  const aliases = [...(tab.systemAliases || [])];
  const aliasGroupLabel = tab.aliasGroupLabel || target.alias_support || target.shell_family || 'terminal';
  els.aliasListNote.textContent = `Tipo de terminal: ${aliasGroupLabel}.`;

  const seen = new Set();
  const uniqueAliases = aliases.filter((item) => {
    const group = normalizeAliasFolder(item.folder || item.group || '');
    const key = `${group}::${item.name}::${item.command}`;
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });

  const groupNames = [...new Set(uniqueAliases.map((item) => displayAliasGroup(item.folder || item.group || '')))].sort((a, b) => a.localeCompare(b, 'es', { sensitivity: 'base' }));
  const currentFilter = tab.aliasGroupFilter || '';
  if (els.aliasGroupFilterSelect) {
    els.aliasGroupFilterSelect.innerHTML = `<option value="">Todos los grupos</option>${groupNames.map((groupName) => `<option value="${escapeHtml(groupName)}" ${groupName === currentFilter ? 'selected' : ''}>${escapeHtml(groupName)}</option>`).join('')}`;
    if (currentFilter && !groupNames.includes(currentFilter)) {
      tab.aliasGroupFilter = '';
      els.aliasGroupFilterSelect.value = '';
    }
    els.aliasGroupFilterField?.classList.remove('hidden');
  }

  const filteredAliases = currentFilter ? uniqueAliases.filter((item) => displayAliasGroup(item.folder || item.group || '') === currentFilter) : uniqueAliases;
  if (!filteredAliases.length) {
    els.aliasList.innerHTML = '<div class="credential-note">No hay alias guardados para este filtro.</div>';
    return;
  }

  els.aliasList.innerHTML = filteredAliases.map((item) => `
    <div class="simple-list-item alias-list-item">
      <div class="alias-item-main">
        <span class="list-meta"><span class="list-label">Alias:</span> ${escapeHtml(item.name || '')}</span>
        <span class="list-meta"><span class="list-label">Grupo:</span> ${escapeHtml(displayAliasGroup(item.folder || item.group || ''))}</span>
        <span class="list-meta"><span class="list-label">Comando:</span> ${escapeHtml(item.command || '')}</span>
      </div>
      <div class="alias-item-actions">
        <button type="button" class="mini-btn alias-mini-btn icon-only" title="Lanzar alias" aria-label="Lanzar alias" data-alias-action="run" data-alias-command="${escapeHtml(item.command || '')}" data-alias-name="${escapeHtml(item.name || '')}"><svg class="alias-btn-svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 6.5v11l9-5.5-9-5.5Z"/></svg></button>
        <button type="button" class="mini-btn danger-btn alias-mini-btn icon-only" title="Borrar alias" aria-label="Borrar alias" data-alias-action="delete" data-alias-id="${escapeHtml(item.id || '')}" data-alias-name="${escapeHtml(item.name || '')}"><svg class="alias-btn-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12"/><path d="M18 6L6 18"/></svg></button>
      </div>
    </div>`).join('');

  els.aliasList.querySelectorAll('[data-alias-action="run"]').forEach((button) => {
    button.addEventListener('click', () => runAliasInActiveTab(button.dataset.aliasCommand || '', button.dataset.aliasName || ''));
  });
  els.aliasList.querySelectorAll('[data-alias-action="delete"]').forEach((button) => {
    button.addEventListener('click', () => deleteAliasForActiveTab(button.dataset.aliasId || '', button.dataset.aliasName || ''));
  });
}

async function refreshAliasList() {
  const tab = getActiveTab();
  const target = tab ? getTargetById(tab.targetId) : null;
  if (!tab || !target || !supportsAliases(target)) {
    renderAliasPanel();
    return;
  }
  try {
    const data = await fetchJson(`/api/aliases?target_id=${encodeURIComponent(tab.targetId)}`);
    tab.systemAliases = Array.isArray(data.aliases) ? data.aliases : [];
    tab.aliasGroup = data.alias_group || '';
    tab.aliasGroupLabel = data.alias_group_label || '';
    renderAliasPanel();
  } catch (error) {
    els.aliasListNote.textContent = error.message;
  }
}


function populateHomeScriptFilters() {
  ensureScriptsArray();
  const tab = getActiveTab();
  const target = tab ? getTargetById(tab.targetId) : null;
  const visibleForTarget = target ? (runtimeConfig.app_scripts || []).filter((script) => scriptMatchesTarget(script, target)) : [];
  const currentCategory = els.scriptCategoryFilterSelect?.value || '';
  const currentSubcategory = els.scriptSubcategoryFilterSelect?.value || '';
  const categories = availableScriptCategories(visibleForTarget);
  if (els.scriptCategoryFilterSelect) {
    els.scriptCategoryFilterSelect.innerHTML = `<option value="">Todas las categorías</option>${categories.map((item) => `<option value="${escapeHtml(item)}" ${item === currentCategory ? 'selected' : ''}>${escapeHtml(item)}</option>`).join('')}`;
    if (currentCategory && !categories.includes(currentCategory)) els.scriptCategoryFilterSelect.value = '';
  }
  const selectedCategory = els.scriptCategoryFilterSelect?.value || '';
  const subcategories = availableScriptSubcategories(visibleForTarget, selectedCategory);
  if (els.scriptSubcategoryFilterSelect) {
    els.scriptSubcategoryFilterSelect.innerHTML = `<option value="">Todas las subcategorías</option>${subcategories.map((item) => `<option value="${escapeHtml(item)}" ${item === currentSubcategory ? 'selected' : ''}>${escapeHtml(item)}</option>`).join('')}`;
    if (currentSubcategory && !subcategories.includes(currentSubcategory)) els.scriptSubcategoryFilterSelect.value = '';
  }
}

function renderScriptsPanel() {
  ensureScriptsArray();
  const tab = getActiveTab();
  const target = tab ? getTargetById(tab.targetId) : null;
  if (!tab || !target) {
    if (els.scriptsNote) els.scriptsNote.textContent = 'Selecciona una pestaña para ver los scripts disponibles.';
    if (els.scriptsList) els.scriptsList.innerHTML = '';
    if (els.scriptsMessage) els.scriptsMessage.textContent = '';
    return;
  }
  populateHomeScriptFilters();
  const scripts = visibleScriptsForActiveTab();
  if (els.scriptsNote) els.scriptsNote.textContent = `Scripts visibles para ${target.label}.`;
  if (!scripts.length) {
    els.scriptsList.innerHTML = '<div class="credential-note">No hay scripts visibles para esta terminal con el filtro actual.</div>';
    return;
  }
  els.scriptsList.innerHTML = scripts.map((script) => `
    <div class="simple-list-item script-list-item">
      <div class="script-item-main">
        <span class="list-meta"><span class="list-label">Script:</span> ${escapeHtml(script.name || '')}</span>
        <span class="list-meta"><span class="list-label">Categoría:</span> ${escapeHtml(script.category || 'General')}</span>
        <span class="list-meta"><span class="list-label">Descripcion:</span> ${escapeHtml(script.description || 'Sin descripción configurada.')}</span>
      </div>
      <div class="script-item-actions">
        <button type="button" class="mini-btn script-mini-btn icon-only" title="Ejecutar script" aria-label="Ejecutar script" data-script-action="run" data-script-id="${escapeHtml(script.id || '')}"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 6.5v11l9-5.5-9-5.5Z"/></svg></button>
      </div>
    </div>`).join('');
  els.scriptsList.querySelectorAll('[data-script-action="run"]').forEach((button) => {
    button.addEventListener('click', () => runScriptInActiveTab(button.dataset.scriptId || ''));
  });
}

function runScriptInActiveTab(scriptId) {
  const tab = getActiveTab();
  const target = tab ? getTargetById(tab.targetId) : null;
  const script = (runtimeConfig?.app_scripts || []).find((item) => item.id === scriptId);
  if (!tab || !target || !script) return;
  const variant = resolveScriptVariantForTarget(script, target);
  const command = shellCommandForTarget(target, variant);
  if (!command) {
    if (els.scriptsMessage) els.scriptsMessage.textContent = 'Este script no tiene ningún comando útil para la terminal activa.';
    return;
  }
  const ok = injectInputIntoTab(tab, command, { execute: true, statusMessage: `Script lanzado: ${script.name}` });
  if (els.scriptsMessage) els.scriptsMessage.textContent = ok ? `Script lanzado: ${script.name}` : 'La pestaña no está conectada.';
}

function populateScriptSelector() {
  ensureScriptsArray();
  populateScriptConfigCategorySelector();
  const scripts = runtimeConfig.app_scripts || [];
  if (!els.scriptSelect) return;
  const selectedCategory = els.scriptConfigCategorySelect?.value || '';
  const visibleScripts = scripts
    .map((script, index) => ({ script, index }))
    .filter(({ script }) => !selectedCategory || String(script.category || 'General') === selectedCategory);
  els.scriptSelect.innerHTML = visibleScripts.map(({ script, index }) => `<option value="${index}">${escapeHtml(script.name || `Script ${index + 1}`)}</option>`).join('');
  if (!scripts.length) {
    selectedScriptIndex = 0;
    if (els.scriptEditor) els.scriptEditor.innerHTML = '<div class="credential-note">No hay scripts configurados todavía.</div>';
    return;
  }
  if (!visibleScripts.length) {
    selectedScriptIndex = 0;
    if (els.scriptEditor) els.scriptEditor.innerHTML = '<div class="credential-note">No hay scripts en la categoría seleccionada.</div>';
    return;
  }
  const visibleIndexes = visibleScripts.map(({ index }) => index);
  if (!visibleIndexes.includes(selectedScriptIndex)) selectedScriptIndex = visibleIndexes[0];
  els.scriptSelect.value = String(selectedScriptIndex);
}

function makeVariantEditor(script, variantKey, title) {
  const variant = script.variants?.[variantKey] || { enabled: variantKey === 'default', path: '', command: '', args: '' };
  return `
    <div class="variant-card" data-script-variant="${escapeHtml(variantKey)}">
      <label class="check-field"><input type="checkbox" data-script-variant-field="enabled" ${variant.enabled ? 'checked' : ''}><span>${escapeHtml(title)}</span></label>
      <div class="script-variant-grid">
        <label class="field"><span>Ruta</span><input type="text" data-script-variant-field="path" value="${escapeHtml(variant.path || '')}" placeholder="Opcional"></label>
        <label class="field"><span>Comando</span><input type="text" data-script-variant-field="command" value="${escapeHtml(variant.command || '')}" placeholder="Ej. python script.py"></label>
        <label class="field full-row"><span>Flags / parámetros</span><input type="text" data-script-variant-field="args" value="${escapeHtml(variant.args || '')}" placeholder="Ej. --force --verbose"></label>
      </div>
    </div>`;
}

function renderScriptEditor() {
  populateScriptSelector();
  ensureScriptsArray();
  const script = runtimeConfig.app_scripts?.[selectedScriptIndex];
  if (!script || !els.scriptEditor) return;
  const targets = currentTargetOptions();
  const visibilityMode = script.include_all_targets ? 'yes' : 'no';
  const sourceHint = script.source_path
    ? `<div class="info-inline full-row">Script detectado en: <code>${escapeHtml(script.source_path)}</code></div>`
    : '';
  const targetChecklist = `
        <div class="field full-row ${script.include_all_targets ? 'hidden' : ''}" data-script-targets-wrap>
          <span>Terminales donde debe aparecer</span>
          <div class="terminal-target-list-shell">
            <div class="terminal-target-list">${targets.map((target) => `
              <label class="terminal-target-line">
                <input type="checkbox" data-script-target="${escapeHtml(target.id)}" ${(script.target_ids || []).includes(target.id) ? 'checked' : ''}>
                <span class="terminal-target-line-text">${escapeHtml(target.label)}</span>
              </label>`).join('')}
            </div>
          </div>
        </div>`;
  els.scriptEditor.innerHTML = `
    <article class="preset-card">
      <div class="preset-card-head">
        <strong>${escapeHtml(script.name || 'Script')}</strong>
      </div>
      <div class="preset-grid script-grid">
        <label class="field"><span>Nombre del script</span><input data-script-field="name" type="text" value="${escapeHtml(script.name || '')}"></label>
        <label class="field"><span>Categoría</span><input data-script-field="category" type="text" value="${escapeHtml(script.category || 'General')}"></label>
        <label class="field full-row"><span>Descripción</span><textarea data-script-field="description" rows="3" placeholder="Describe brevemente qué hace este script">${escapeHtml(script.description || '')}</textarea></label>
        <label class="field"><span>Subcategoría</span><input data-script-field="subcategory" type="text" value="${escapeHtml(script.subcategory || 'General')}"></label>
        <label class="field"><span>Disponible en todas las terminales</span>
          <select data-script-field="include_all_targets_select">
            <option value="yes" ${visibilityMode === 'yes' ? 'selected' : ''}>Sí</option>
            <option value="no" ${visibilityMode === 'no' ? 'selected' : ''}>No</option>
          </select>
        </label>
        ${sourceHint}
        ${targetChecklist}
        <div class="field full-row">
          <span>Configuración base</span>
          ${makeVariantEditor(script, 'default', 'Usar como configuración base')}
        </div>
        <div class="field full-row">
          <span>Overrides por tipo de terminal</span>
          <div class="terminal-target-checklist">
            ${makeVariantEditor(script, 'powershell', 'PowerShell')}
            ${makeVariantEditor(script, 'cmd', 'CMD')}
            ${makeVariantEditor(script, 'posix', 'POSIX / Bash / WSL')}
            ${makeVariantEditor(script, 'generic', 'Genérico')}
          </div>
        </div>
      </div>
    </article>`;

  els.scriptEditor.querySelectorAll('[data-script-field]').forEach((input) => {
    const handler = () => {
      const field = input.dataset.scriptField;
      if (field === 'include_all_targets_select') {
        script.include_all_targets = input.value !== 'no';
        if (script.include_all_targets) script.target_ids = [];
        const targetsWrap = els.scriptEditor?.querySelector('[data-script-targets-wrap]');
        if (targetsWrap) targetsWrap.classList.toggle('hidden', script.include_all_targets);
        renderScriptsPanel();
        return;
      }
      script[field] = input.value;
      if (field === 'name') populateScriptSelector();
      renderScriptsPanel();
    };
    input.addEventListener('change', handler);
    if (input.tagName === 'INPUT') input.addEventListener('input', handler);
  });

  els.scriptEditor.querySelectorAll('[data-script-target]').forEach((input) => {
    input.addEventListener('change', () => {
      const targetId = input.dataset.scriptTarget || '';
      if (!Array.isArray(script.target_ids)) script.target_ids = [];
      if (input.checked) {
        if (!script.target_ids.includes(targetId)) script.target_ids.push(targetId);
      } else {
        script.target_ids = script.target_ids.filter((value) => value !== targetId);
      }
      renderScriptsPanel();
    });
  });

  els.scriptEditor.querySelectorAll('[data-script-variant]').forEach((card) => {
    const variantKey = card.dataset.scriptVariant;
    card.querySelectorAll('[data-script-variant-field]').forEach((input) => {
      const handler = () => {
        if (!script.variants[variantKey]) script.variants[variantKey] = { enabled: variantKey === 'default', path: '', command: '', args: '' };
        const field = input.dataset.scriptVariantField;
        script.variants[variantKey][field] = input.type === 'checkbox' ? !!input.checked : input.value;
      };
      input.addEventListener('change', handler);
      if (input.tagName === 'INPUT' && input.type !== 'checkbox') input.addEventListener('input', handler);
    });
  });
}

async function saveScriptsConfig() {
  ensureScriptsArray();
  if (els.scriptsViewMessage) els.scriptsViewMessage.textContent = '';
  const response = await fetchJson('/api/scripts/save', { method: 'POST', body: JSON.stringify({ scripts: runtimeConfig.app_scripts || [] }) });
  runtimeConfig = response.config;
  ensureScriptsArray();
  populateTopSessionSelectors();
  renderScriptEditor();
  renderScriptsPanel();
  if (els.scriptsViewMessage) els.scriptsViewMessage.textContent = 'Scripts guardados.';
}

function credentialFieldHtml(kind, label, value = '', type = 'text', placeholder = '') {
  return `<label class="field"><span>${escapeHtml(label)}</span><input data-cred="${escapeHtml(kind)}" type="${escapeHtml(type)}" value="${escapeHtml(value)}" placeholder="${escapeHtml(placeholder)}" autocomplete="off"></label>`;
}

function textareaFieldHtml(kind, label, value = '', placeholder = '') {
  return `<label class="field"><span>${escapeHtml(label)}</span><textarea data-cred="${escapeHtml(kind)}" rows="4" placeholder="${escapeHtml(placeholder)}">${escapeHtml(value)}</textarea></label>`;
}

function renderNewTabCredentialFields() {
  const scope = els.newTabScopeSelect.value;
  els.newTabAuthField.classList.toggle('hidden', scope !== 'remote');
  const target = getTargetById(els.newTabTargetSelect.value) || getTargetsForNewTab()[0] || null;
  const remoteDefaults = runtimeConfig.remote_defaults || {};
  if (scope !== 'remote') {
    els.newTabCredentialFields.innerHTML = scope === 'docker' ? '<div class="credential-note">Los targets Docker se generan automáticamente con los contenedores que están corriendo ahora mismo.</div>' : '';
    return;
  }
  const auth = els.newTabAuthSelect.value;
  const chunks = [
    credentialFieldHtml('host', 'Host remoto', target?.host || remoteDefaults.host || '', 'text', 'Ej. 192.168.1.50'),
    credentialFieldHtml('port', 'Puerto SSH', String(target?.port || remoteDefaults.port || 22), 'number', '22'),
    credentialFieldHtml('username', 'Usuario SSH', target?.username || remoteDefaults.username || '', 'text', 'Ej. admin'),
  ];
  if (auth === 'password') {
    chunks.push(credentialFieldHtml('password', 'Contraseña', '', 'password', 'Solo memoria de esta pestaña'));
  } else {
    chunks.push(credentialFieldHtml('private_key_path', 'Ruta de clave privada', target?.private_key_path || remoteDefaults.private_key_path || '', 'text', 'Opcional si cargas fichero'));
    chunks.push(credentialFieldHtml('passphrase', 'Passphrase', '', 'password', 'Opcional'));
    chunks.push('<label class="field"><span>Public key</span><input data-cred-file="public_key_file" type="file" accept=".pub,text/plain"></label>');
    chunks.push('<label class="field"><span>Private key</span><input data-cred-file="private_key_file" type="file" accept=".pem,.key,.txt,text/plain"></label>');
    chunks.push('<div id="newTabKeyFileInfo" class="info-inline"></div>');
  }
  els.newTabCredentialFields.innerHTML = chunks.join('');
}

function collectNewTabCredentials() {
  const scope = els.newTabScopeSelect.value;
  if (scope !== 'remote') return {};
  const credentials = {
    host: '', port: 22, username: '', password: '', private_key_path: '', passphrase: '', private_key_content: '', public_key_content: '',
  };
  els.newTabCredentialFields.querySelectorAll('[data-cred]').forEach((input) => {
    credentials[input.dataset.cred] = input.value;
  });
  const privateFile = els.newTabCredentialFields.querySelector('[data-cred-file="private_key_file"]');
  const publicFile = els.newTabCredentialFields.querySelector('[data-cred-file="public_key_file"]');
  return Promise.all([
    privateFile?.files?.[0] ? readFileAsText(privateFile.files[0]) : Promise.resolve(''),
    publicFile?.files?.[0] ? readFileAsText(publicFile.files[0]) : Promise.resolve(''),
  ]).then(([privateText, publicText]) => {
    credentials.private_key_content = privateText;
    credentials.public_key_content = publicText;
    return credentials;
  });
}

function renderCredentialFields() {
  const tab = getActiveTab();
  const target = tab ? getTargetById(tab.targetId) : null;
  els.credentialFields.innerHTML = '';
  renderTerminalMeta();
  renderCommandHistory();
  renderAliasPanel();
  renderScriptsPanel();
  if (!tab || !target) return;
  const chunks = [];
  if (target.connection_scope === 'remote') {
    chunks.push(credentialFieldHtml('host', 'Host remoto', tab.credentials.host || target.host || '', 'text', 'Ej. 192.168.1.50'));
    chunks.push(credentialFieldHtml('port', 'Puerto SSH', String(tab.credentials.port || target.port || 22), 'number', '22'));
    chunks.push(credentialFieldHtml('username', 'Usuario SSH', tab.credentials.username || target.username || '', 'text', 'Ej. admin'));
    if ((target.auth_type || 'password') === 'password') {
      chunks.push(credentialFieldHtml('password', 'Contraseña SSH efímera', tab.credentials.password || '', 'password', 'Solo para esta pestaña'));
    } else {
      chunks.push(credentialFieldHtml('private_key_path', 'Ruta de clave privada', tab.credentials.private_key_path || target.private_key_path || '', 'text', 'Opcional si cargas fichero'));
      chunks.push(credentialFieldHtml('passphrase', 'Passphrase efímera', tab.credentials.passphrase || '', 'password', 'Vacía si no tiene'));
      chunks.push('<label class="field"><span>Reemplazar private key</span><input data-cred-file="private_key_file" type="file" accept=".pem,.key,.txt,text/plain"></label>');
      chunks.push('<div id="activeKeyFileInfo" class="info-inline"></div>');
    }
  } else {
    chunks.push(`<div class="credential-note">Esta pestaña usa un target ${target.connection_scope === 'docker' ? 'Docker' : 'local'} fijo. No se puede cambiar su target después de crearla.</div>`);
  }
  els.credentialFields.innerHTML = chunks.join('');

  els.credentialFields.querySelectorAll('[data-cred]').forEach((input) => {
    input.addEventListener('input', () => {
      updateActiveTabState();
      renderTerminalMeta();
    });
  });

  const privateKeyFile = els.credentialFields.querySelector('[data-cred-file="private_key_file"]');
  if (privateKeyFile) {
    privateKeyFile.addEventListener('change', async () => {
      const active = getActiveTab();
      if (!active) return;
      active.credentials.private_key_content = await readFileAsText(privateKeyFile.files?.[0]);
      renderCredentialFields();
    });
  }
}

function createTerminalForPane(host, scrollback) {
  const term = new Terminal({
    cursorBlink: true,
    convertEol: true,
    scrollback: Number(scrollback),
    fontFamily: 'Cascadia Mono, Consolas, Menlo, monospace',
    fontSize: 15,
    lineHeight: 1.2,
    theme: {
      background: '#090304',
      foreground: '#f7edf0',
      cursor: '#f1c8cf',
      selectionBackground: 'rgba(195, 74, 96, 0.28)',
    },
  });
  const fitAddon = new FitAddon.FitAddon();
  term.loadAddon(fitAddon);
  term.open(host);
  requestAnimationFrame(() => {
    fitAddon.fit();
    term.focus();
  });
  return { term, fitAddon };
}

function normalizeTerminalInputPayload(text, { execute = false } = {}) {
  const normalized = String(text || '').replace(/\r\n/g, '\n').replace(/\r/g, '\n');
  const payload = normalized.replace(/\n/g, '\r');
  return execute ? `${payload}\r` : payload;
}

function injectInputIntoTab(tab, text, { execute = false, statusMessage = '', emptyMessage = '' } = {}) {
  if (!tab) return false;
  if (!tab.socket || tab.socket.readyState !== WebSocket.OPEN) {
    tab.lastStatus = 'La pestaña no está conectada';
    if (tab.id === activeTabId) renderTerminalMeta();
    return false;
  }
  const payload = normalizeTerminalInputPayload(text, { execute });
  if (!payload) {
    if (emptyMessage) {
      tab.lastStatus = emptyMessage;
      if (tab.id === activeTabId) renderTerminalMeta();
    }
    return false;
  }
  try {
    tab.term.focus();
  } catch {}
  tab.term.input(payload, true);
  if (statusMessage) {
    tab.lastStatus = statusMessage;
    if (tab.id === activeTabId) renderTerminalMeta();
  }
  return true;
}

async function copyTerminalSelection(tab, { statusMessage = 'Selección copiada al portapapeles', clearSelection = true } = {}) {
  if (!tab?.term) return false;
  const text = tab.term.getSelection();
  if (!text) {
    tab.lastStatus = 'No hay texto seleccionado en la terminal';
    if (tab.id === activeTabId) renderTerminalMeta();
    return false;
  }
  try {
    await navigator.clipboard.writeText(text);
    if (clearSelection) {
      try { tab.term.clearSelection(); } catch {}
    }
    tab.lastStatus = statusMessage;
    if (tab.id === activeTabId) renderTerminalMeta();
    try { tab.term.focus(); } catch {}
    return true;
  } catch {
    tab.lastStatus = 'No se pudo copiar la selección al portapapeles';
    if (tab.id === activeTabId) renderTerminalMeta();
    return false;
  }
}

function bindTerminalKeyboardShortcuts(tab) {
  if (!tab?.term || tab.term.__zenotermKeyboardBindingsInstalled) return;
  tab.term.__zenotermKeyboardBindingsInstalled = true;
  tab.term.attachCustomKeyEventHandler((event) => {
    if (event.type !== 'keydown') return true;
    const key = String(event.key || '').toLowerCase();
    const accel = event.ctrlKey || event.metaKey;
    const hasSelection = !!tab.term.hasSelection?.();

    const stopAndRun = (callback) => {
      event.preventDefault();
      event.stopPropagation();
      queueMicrotask(() => Promise.resolve(callback()).catch(() => {}));
      return false;
    };

    if ((accel && !event.shiftKey && key === 'c')) {
      if (hasSelection) return stopAndRun(() => copyTerminalSelection(tab));
      return true;
    }
    if ((accel && !event.shiftKey && key === 'v')) {
      return stopAndRun(() => pasteIntoTab(tab));
    }
    if ((accel && event.shiftKey && key === 'c') || (event.ctrlKey && !event.shiftKey && key === 'insert')) {
      return stopAndRun(() => copyTerminalSelection(tab));
    }
    if ((accel && event.shiftKey && key === 'v') || (event.shiftKey && !event.ctrlKey && !event.metaKey && key === 'insert')) {
      return stopAndRun(() => pasteIntoTab(tab));
    }
    return true;
  });
}

function hideTabContextMenu() {
  if (tabContextMenu) tabContextMenu.classList.add('hidden');
}

function hideTerminalContextMenu() {
  if (terminalContextMenu) terminalContextMenu.classList.add('hidden');
}

function ensureTabContextMenu() {
  if (tabContextMenu) return tabContextMenu;
  tabContextMenu = document.createElement('div');
  tabContextMenu.className = 'tab-context-menu hidden';
  tabContextMenu.innerHTML = '<button type="button" data-action="rename-tab">Cambiar nombre</button>';
  document.body.appendChild(tabContextMenu);
  tabContextMenu.querySelector('[data-action="rename-tab"]').addEventListener('click', () => {
    const tabId = tabContextMenu?.dataset?.tabId || '';
    hideTabContextMenu();
    if (tabId) renameTab(tabId);
  });
  return tabContextMenu;
}

function showTabContextMenu(tabId, clientX, clientY) {
  const menu = ensureTabContextMenu();
  menu.dataset.tabId = tabId;
  menu.classList.remove('hidden');
  const viewportWidth = window.innerWidth || document.documentElement.clientWidth || 0;
  const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
  const menuRect = menu.getBoundingClientRect();
  const left = Math.max(8, Math.min(clientX, viewportWidth - menuRect.width - 8));
  const top = Math.max(8, Math.min(clientY, viewportHeight - menuRect.height - 8));
  menu.style.left = `${left}px`;
  menu.style.top = `${top}px`;
}

function ensureTerminalContextMenu() {
  if (terminalContextMenu) return terminalContextMenu;
  terminalContextMenu = document.createElement('div');
  terminalContextMenu.className = 'tab-context-menu hidden';
  terminalContextMenu.innerHTML = '<button type="button" data-action="paste-clipboard">Pegar portapapeles</button>';
  document.body.appendChild(terminalContextMenu);
  terminalContextMenu.querySelector('[data-action="paste-clipboard"]').addEventListener('click', async () => {
    const tabId = terminalContextMenu?.dataset?.tabId || '';
    hideTerminalContextMenu();
    const tab = tabs.find((item) => item.id === tabId);
    if (tab) await pasteIntoTab(tab);
  });
  return terminalContextMenu;
}

function showTerminalContextMenu(tabId, clientX, clientY) {
  const menu = ensureTerminalContextMenu();
  menu.dataset.tabId = tabId;
  menu.classList.remove('hidden');
  const viewportWidth = window.innerWidth || document.documentElement.clientWidth || 0;
  const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
  const menuRect = menu.getBoundingClientRect();
  const left = Math.max(8, Math.min(clientX, viewportWidth - menuRect.width - 8));
  const top = Math.max(8, Math.min(clientY, viewportHeight - menuRect.height - 8));
  menu.style.left = `${left}px`;
  menu.style.top = `${top}px`;
}

function renameTab(tabId) {
  const tab = tabs.find((item) => item.id === tabId);
  if (!tab) return;
  const nextTitle = window.prompt('Nuevo nombre de la pestaña:', tab.title || '');
  if (nextTitle === null) return;
  const cleanTitle = String(nextTitle || '').trim();
  if (!cleanTitle) return;
  tab.title = cleanTitle;
  renderTabs();
  if (tab.id === activeTabId) renderTerminalMeta();
}

function renderTabs() {
  hideTabContextMenu();
  els.tabsList.innerHTML = '';
  tabs.forEach((tab) => {
    const chip = document.createElement('div');
    chip.className = `tab-chip ${tab.id === activeTabId ? 'active' : ''}`;
    chip.innerHTML = `<span>${escapeHtml(tab.title)}</span><button type="button" aria-label="Cerrar">×</button>`;
    chip.addEventListener('click', () => activateTab(tab.id));
    chip.addEventListener('contextmenu', (event) => {
      event.preventDefault();
      activateTab(tab.id);
      showTabContextMenu(tab.id, event.clientX, event.clientY);
    });
    chip.querySelector('button').addEventListener('click', (event) => {
      event.stopPropagation();
      closeTab(tab.id);
    });
    els.tabsList.appendChild(chip);
  });
}

function updateActiveTabState() {
  const tab = getActiveTab();
  if (!tab) return null;
  els.credentialFields.querySelectorAll('[data-cred]').forEach((input) => {
    tab.credentials[input.dataset.cred] = input.value;
  });
  return tab;
}

function activateTab(tabId) {
  activeTabId = tabId;
  tabs.forEach((tab) => tab.pane.classList.toggle('active', tab.id === tabId));
  renderTabs();
  renderCredentialFields();
  refreshAliasList();
  renderScriptsPanel();
  const tab = getActiveTab();
  if (tab) {
    requestAnimationFrame(() => {
      try {
        tab.fitAddon.fit();
        tab.term.focus();
      } catch {}
    });
  }
}

function openSocketForTab(tab, actionType = 'start') {
  try { tab.socket?.close(); } catch {}
  tab.socket = new WebSocket(`${location.protocol === 'https:' ? 'wss' : 'ws'}://${location.host}/ws`);

  tab.socket.addEventListener('open', () => {
    sendStartPayload(tab, actionType);
  });

  tab.socket.addEventListener('message', (event) => {
    const payload = JSON.parse(event.data);
    if (payload.type === 'output') {
      tab.term.write(payload.data);
      tab.currentPath = detectCurrentPath(tab);
      if (tab.id === activeTabId) renderTerminalMeta();
      return;
    }
    if (payload.type === 'status') {
      tab.lastStatus = payload.message || payload.status;
      tab.connected = payload.status === 'connected';
      if (payload.status === 'closed' || payload.status === 'error') tab.connected = false;
      if (payload.status === 'error') tab.term.writeln(`\r\n[ERROR] ${payload.message}\r\n`);
      if (tab.id === activeTabId) renderTerminalMeta();
      renderTabs();
    }
  });

  tab.socket.addEventListener('close', () => {
    tab.connected = false;
    tab.lastStatus = 'Conexión cerrada';
    if (tab.id === activeTabId) renderTerminalMeta();
    renderTabs();
  });

  tab.socket.addEventListener('error', () => {
    tab.connected = false;
    tab.lastStatus = 'Error de WebSocket';
    if (tab.id === activeTabId) renderTerminalMeta();
    renderTabs();
  });
}

function sendStartPayload(tab, type = 'start') {
  const target = getTargetById(tab.targetId);
  if (!target) return;
  tab.fitAddon.fit();
  tab.term.reset();
  tab.lastStatus = `${type === 'restart' ? 'Reconectando' : 'Conectando'} a ${target.label}…`;
  tab.connected = false;
  tab.socket.send(JSON.stringify({
    type,
    target_id: tab.targetId,
    cols: tab.term.cols,
    rows: tab.term.rows,
    credentials: tab.credentials || {},
  }));
  renderTabs();
  renderTerminalMeta();
}

function createTab(config = {}) {
  const pane = document.createElement('div');
  pane.className = 'terminal-pane';
  const host = document.createElement('div');
  host.className = 'terminal-host';
  pane.appendChild(host);
  els.terminalStack.appendChild(pane);

  const scrollback = Number(config.scrollback || runtimeConfig.ui.default_scrollback || 20000);
  const { term, fitAddon } = createTerminalForPane(host, scrollback);
  const tab = {
    id: uid(),
    title: config.title,
    targetId: config.targetId,
    scrollback,
    credentials: { ...(config.credentials || {}) },
    pane,
    host,
    term,
    fitAddon,
    socket: null,
    connected: false,
    lastStatus: 'Sin iniciar',
    currentPath: getTargetById(config.targetId)?.workspace_dir || runtimeConfig.workspace_dir || 'Desconocido',
    commandHistory: [],
    pendingCommand: '',
    systemAliases: [],
    aliasGroup: '',
    aliasGroupLabel: '',
  };

  bindTerminalKeyboardShortcuts(tab);

  host.addEventListener('mousedown', () => {
    if (tab.id !== activeTabId) activateTab(tab.id);
    requestAnimationFrame(() => {
      try { tab.term.focus(); } catch {}
    });
  });

  host.addEventListener('contextmenu', async (event) => {
    event.preventDefault();
    hideTabContextMenu();
    hideTerminalContextMenu();
    if (tab.id !== activeTabId) activateTab(tab.id);
    await pasteIntoTab(tab);
    try { tab.term.focus(); } catch {}
  });

  term.onData((data) => {
    if (data === '\r') {
      pushCommandHistory(tab, tab.pendingCommand);
      tab.pendingCommand = '';
    } else if (data === '\u007f') {
      tab.pendingCommand = tab.pendingCommand.slice(0, -1);
    } else if (data === '\u0003') {
      tab.pendingCommand = '';
    } else if (!data.startsWith('\u001b')) {
      tab.pendingCommand += data;
    }
    if (tab.socket && tab.socket.readyState === WebSocket.OPEN) tab.socket.send(JSON.stringify({ type: 'input', data }));
  });
  term.onResize(({ cols, rows }) => {
    if (tab.socket && tab.socket.readyState === WebSocket.OPEN) tab.socket.send(JSON.stringify({ type: 'resize', cols, rows }));
  });

  tabs.push(tab);
  activateTab(tab.id);
  renderTabs();
  return tab;
}

function closeTab(tabId) {
  const index = tabs.findIndex((tab) => tab.id === tabId);
  if (index === -1) return;
  const tab = tabs[index];
  try {
    if (tab.socket && tab.socket.readyState === WebSocket.OPEN) {
      tab.socket.send(JSON.stringify({ type: 'close' }));
      tab.socket.close();
    }
  } catch {}
  try { tab.term.dispose(); } catch {}
  tab.pane.remove();
  tabs.splice(index, 1);
  if (!tabs.length) {
    renderTabs();
    renderTerminalMeta();
    els.credentialFields.innerHTML = '';
    renderCommandHistory();
    renderAliasPanel();
    renderScriptsPanel();
    return;
  }
  activateTab(tabs[Math.max(0, index - 1)].id);
}

function extractTerminalText(tab) {
  return Array.from({ length: tab.term.buffer.active.length }, (_, i) => tab.term.buffer.active.getLine(i)?.translateToString(true) || '').join('\n');
}

async function copyActiveTab() {
  const tab = getActiveTab();
  if (!tab) return;
  const text = extractTerminalText(tab);
  try {
    await navigator.clipboard.writeText(text);
    tab.lastStatus = 'Copiado al portapapeles';
    renderTerminalMeta();
  } catch {
    tab.lastStatus = 'No se pudo copiar automáticamente';
    renderTerminalMeta();
  }
}

async function pasteIntoTab(tab) {
  if (!tab) return;
  if (!tab.socket || tab.socket.readyState !== WebSocket.OPEN) {
    tab.lastStatus = 'No hay una sesión activa para pegar';
    if (tab.id === activeTabId) renderTerminalMeta();
    return;
  }
  try {
    const clipboardText = await navigator.clipboard.readText();
    const text = String(clipboardText || '');
    if (!text) {
      tab.lastStatus = 'El portapapeles del navegador está vacío';
      if (tab.id === activeTabId) renderTerminalMeta();
      return;
    }
    injectInputIntoTab(tab, text, {
      statusMessage: 'Texto pegado desde el portapapeles local del navegador',
      emptyMessage: 'El portapapeles del navegador está vacío',
    });
  } catch {
    tab.lastStatus = 'No se pudo leer el portapapeles del navegador';
    if (tab.id === activeTabId) renderTerminalMeta();
  }
}

async function pasteIntoActiveTab() {
  const tab = getActiveTab();
  if (!tab) return;
  await pasteIntoTab(tab);
}

function writeImportSummaryToTerminal(tab, data, overwrite) {
  if (!tab?.term || !data?.result) return;
  const result = data.result || {};
  const details = result.details || {};
  const lines = [];
  lines.push('');
  lines.push(`[Zenoterm] Importación de carpeta ${overwrite ? 'con reemplazo' : 'sin reemplazo'}`);
  lines.push(`[Zenoterm] Copiados: ${result.copied || 0} | Reemplazados: ${result.overwritten || 0} | Omitidos: ${result.skipped || 0}`);

  const appendGroup = (label, items) => {
    const list = Array.isArray(items) ? items : [];
    if (!list.length) return;
    const preview = list.slice(0, 8);
    preview.forEach((item) => lines.push(`[Zenoterm] ${label}: ${item}`));
    if (list.length > preview.length) {
      lines.push(`[Zenoterm] ${label}: ... y ${list.length - preview.length} más`);
    }
  };

  appendGroup('Copiado', details.copied);
  appendGroup('Reemplazado', details.overwritten);
  appendGroup('Omitido', details.skipped);
  tab.term.writeln(lines.join('\r\n'));
}

function pickDirectoryFiles() {
  return new Promise((resolve) => {
    const input = document.createElement('input');
    input.type = 'file';
    input.multiple = true;
    input.setAttribute('webkitdirectory', '');
    input.setAttribute('directory', '');
    input.style.position = 'fixed';
    input.style.left = '-9999px';
    document.body.appendChild(input);
    input.addEventListener('change', () => {
      const files = Array.from(input.files || []);
      input.remove();
      resolve(files);
    }, { once: true });
    input.click();
  });
}

async function importDirectoryIntoActiveTab(overwrite) {
  const tab = getActiveTab();
  if (!tab) return;
  const currentPath = detectCurrentPath(tab);
  if (!currentPath || currentPath === 'Desconocido') {
    tab.lastStatus = 'No se pudo detectar la ruta actual de la terminal';
    renderTerminalMeta();
    return;
  }
  try {
    const files = await pickDirectoryFiles();
    if (!files.length) {
      tab.lastStatus = 'No se seleccionó ninguna carpeta o estaba vacía';
      renderTerminalMeta();
      return;
    }
    const formData = new FormData();
    formData.append('target_id', tab.targetId);
    formData.append('current_path', currentPath);
    formData.append('overwrite', overwrite ? 'true' : 'false');
    files.forEach((file) => {
      const relativeName = file.webkitRelativePath || file.name;
      formData.append('files', file, relativeName);
    });
    const response = await fetch('/api/import/current-path', {
      method: 'POST',
      body: formData,
    });
    let data = {};
    try { data = await response.json(); } catch {}
    if (!response.ok || !data.ok) {
      throw new Error(data.message || 'No se pudo copiar la carpeta seleccionada');
    }
    tab.lastStatus = data.message || (overwrite ? 'Carpeta copiada sobrescribiendo duplicados' : 'Carpeta copiada sin sobrescribir duplicados');
    writeImportSummaryToTerminal(tab, data, overwrite);
    renderTerminalMeta();
  } catch (error) {
    tab.lastStatus = error.message || 'No se pudo copiar la carpeta seleccionada';
    renderTerminalMeta();
  }
}

async function downloadActiveTabCurrentPathZip() {
  const tab = getActiveTab();
  if (!tab) return;
  const target = getTargetById(tab.targetId);
  const currentPath = detectCurrentPath(tab);
  if (!currentPath || currentPath === 'Desconocido') {
    tab.lastStatus = 'No se pudo detectar la ruta actual de la terminal';
    renderTerminalMeta();
    return;
  }
  try {
    const response = await fetch('/api/download/current-path', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ target_id: tab.targetId, current_path: currentPath }),
    });
    if (!response.ok) {
      let message = 'No se pudo preparar la descarga del zip';
      try {
        const data = await response.json();
        message = data.message || message;
      } catch {}
      throw new Error(message);
    }
    const blob = await response.blob();
    const blobUrl = URL.createObjectURL(blob);
    const contentDisposition = response.headers.get('Content-Disposition') || '';
    const match = contentDisposition.match(/filename\*=UTF-8''([^;]+)|filename="?([^";]+)"?/i);
    const fallbackBase = (tab.title || target?.id || 'carpeta').replace(/[^a-z0-9-_]+/gi, '_').replace(/^_+|_+$/g, '') || 'carpeta';
    const filename = decodeURIComponent((match?.[1] || match?.[2] || `${fallbackBase}.zip`).trim());
    const anchor = document.createElement('a');
    anchor.href = blobUrl;
    anchor.download = filename;
    document.body.appendChild(anchor);
    anchor.click();
    anchor.remove();
    URL.revokeObjectURL(blobUrl);
    tab.lastStatus = `Descarga iniciada: ${currentPath}`;
    renderTerminalMeta();
  } catch (error) {
    tab.lastStatus = error.message || 'No se pudo descargar la ruta actual en zip';
    renderTerminalMeta();
  }
}

function saveActiveTabOutput() {
  const tab = getActiveTab();
  if (!tab) return;
  const target = getTargetById(tab.targetId);
  const safeTitle = (tab.title || 'terminal').replace(/[^a-z0-9-_]+/gi, '_').replace(/^_+|_+$/g, '') || 'terminal';
  const date = new Date().toISOString().replace(/[:.]/g, '-');
  const text = extractTerminalText(tab);
  const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const anchor = document.createElement('a');
  anchor.href = url;
  anchor.download = `${safeTitle}_${target?.id || 'target'}_${date}.txt`;
  document.body.appendChild(anchor);
  anchor.click();
  anchor.remove();
  URL.revokeObjectURL(url);
  tab.lastStatus = 'Salida guardada en fichero local';
  renderTerminalMeta();
}

function buildTreeCommandForTarget(target) {
  const family = String(target?.shell_family || '').toLowerCase();
  const os = String(target?.target_os || runtimeConfig.host_os || '').toLowerCase();
  if (family === 'cmd') return 'tree /A /F';
  if (family === 'pwsh' || family === 'powershell') return 'tree /A /F .';
  if (os === 'windows') return 'tree /A /F .';
  return "if command -v tree >/dev/null 2>&1; then tree -a .; else find . -print | sed -e 's;[^/]*/;|   ;g' -e 's;|   \\([^|]\\);|--- \\1;'; fi";
}

function printActiveTabPathTree() {
  const tab = getActiveTab();
  if (!tab) return;
  const target = getTargetById(tab.targetId);
  if (!target) return;
  const command = buildTreeCommandForTarget(target);
  if (!command) return;
  injectInputIntoTab(tab, command, {
    execute: true,
    statusMessage: 'Árbol del path actual enviado a la terminal',
  });
}


function connectActiveTab(type = 'restart') {
  const tab = updateActiveTabState();
  if (!tab) return;
  openSocketForTab(tab, type);
}

async function handleLogin(event) {
  event.preventDefault();
  els.loginMessage.textContent = '';
  try {
    const data = await fetchJson('/api/auth/login', { method: 'POST', body: JSON.stringify({ username: els.loginUsername.value, password: els.loginPassword.value }) });
    authStatus.authenticated = !!data.authenticated;
    authStatus.current_user = data.current_user || null;
    await reloadRuntimeConfig();
    ensureAuthenticatedUi();
    els.loginPassword.value = '';
    autoOpenDefaultSessionTabs();
  } catch (error) {
    els.loginMessage.textContent = error.message;
  }
}

async function handleLogout() {
  await fetchJson('/api/auth/logout', { method: 'POST', body: JSON.stringify({}) });
  authStatus.authenticated = false;
  authStatus.current_user = null;
  await reloadRuntimeConfig();
  ensureAuthenticatedUi();
  showMainView();
  for (const tab of tabs) {
    try { tab.socket?.close(); } catch {}
    tab.connected = false;
    tab.lastStatus = 'Sesión cerrada por logout';
  }
  renderTabs();
  renderTerminalMeta();
}

async function createNewTabFromControls() {
  const title = (els.newTabName.value || '').trim();
  if (!title) {
    els.newTabName.focus();
    return;
  }
  const targetId = els.newTabTargetSelect.value;
  const credentials = await collectNewTabCredentials();
  const tab = createTab({ title, targetId, scrollback: Number(runtimeConfig.ui.default_scrollback || 20000), credentials });
  els.newTabName.value = '';
  els.newTabName.dataset.autoValue = '';
  syncNewTabNameWithTarget(true);
  renderNewTabCredentialFields();
  openSocketForTab(tab, 'start');
}

function buildPresetOptionLabel(preset, index, presets) {
  const effectivePreset = getSessionPresetView(preset, selectedConfigSessionId);
  const remotePresets = presets.filter((item) => item.scope === 'remote');
  const localCustomPresets = presets.filter((item) => item.scope === 'local' && !item.detected_local);
  if (preset.scope === 'remote') {
    const remoteIndex = remotePresets.findIndex((item) => item === preset) + 1;
    return `Remota ${remoteIndex}: ${effectivePreset.name || preset.name || `Terminal remota ${remoteIndex}`}`;
  }
  if (preset.detected_local) {
    return `Local detectada: ${effectivePreset.name || preset.name || `Terminal ${index + 1}`}`;
  }
  const localIndex = localCustomPresets.findIndex((item) => item === preset) + 1;
  return `Local ${localIndex}: ${effectivePreset.name || preset.name || `Terminal local ${localIndex}`}`;
}

function populatePresetSelector() {
  const presets = runtimeConfig.terminal_presets || [];
  els.terminalPresetSelect.innerHTML = presets.map((preset, index) => `<option value="${index}">${escapeHtml(buildPresetOptionLabel(preset, index, presets))}</option>`).join('');
  if (!presets.length) {
    selectedPresetIndex = 0;
    els.terminalPresetList.innerHTML = '<div class="credential-note">No hay terminales configuradas todavía.</div>';
    return;
  }
  if (selectedPresetIndex >= presets.length) selectedPresetIndex = presets.length - 1;
  els.terminalPresetSelect.value = String(selectedPresetIndex);
}

function makePresetCard(preset, index) {
  const effectivePreset = getSessionPresetView(preset, selectedConfigSessionId);
  const isRemote = effectivePreset.scope === 'remote';
  const isLocal = effectivePreset.scope === 'local';
  const isDetectedLocal = !!effectivePreset.detected_local;
  const authType = effectivePreset.auth_type || (isRemote ? 'password' : 'none');
  const commandSource = normalizeCommandSource(effectivePreset);
  const showText = commandSource !== 'file';
  const showFile = commandSource === 'file';
  const removeButton = selectedConfigSessionId !== 'general'
    ? `<button type="button" data-clear-session-override="${escapeHtml(effectivePreset.id || '')}">Limpiar override</button>`
    : (preset.editable_remove === false ? '' : `<button type="button" data-remove-preset="${index}">Eliminar</button>`);
  const hostOsLabel = escapeHtml(runtimeConfig.host_os_label || runtimeConfig.host_os || 'Host actual');
  const targetOsControl = isLocal
    ? `<input type="text" value="${hostOsLabel}" disabled>`
    : `<select data-preset="target_os">${targetOsOptions().map((item) => `<option value="${escapeHtml(item.id)}" ${item.id === (effectivePreset.target_os || runtimeConfig.host_os) ? 'selected' : ''}>${escapeHtml(item.label)}</option>`).join('')}</select>`;
  return `
    <article class="preset-card" data-index="${index}">
      <div class="preset-card-head">
        <strong>${escapeHtml(effectivePreset.name || `Terminal ${index + 1}`)}</strong>
        ${removeButton}
      </div>
      ${isDetectedLocal ? '<div class="info-inline">Esta terminal local se detecta automáticamente desde el host actual. Aquí solo ajustas su comportamiento dentro de Zenoterm.</div>' : ''}
      ${selectedConfigSessionId !== 'general' ? '<div class="info-inline">Estás editando la configuración personalizada de una sesión. Si limpias el override, volverá a usar la configuración general.</div>' : ''}
      <div class="preset-grid">
        <label class="field"><span>Nombre</span><input data-preset="name" type="text" value="${escapeHtml(effectivePreset.name || '')}"></label>
        <label class="field"><span>Tipo</span>
          <select data-preset="scope" ${preset.editable_scope === false || selectedConfigSessionId !== 'general' ? 'disabled' : ''}>
            <option value="local" ${effectivePreset.scope === 'local' ? 'selected' : ''}>Local</option>
            <option value="remote" ${effectivePreset.scope === 'remote' ? 'selected' : ''}>Remota</option>
          </select>
        </label>
        <label class="check-field"><input data-preset="open_by_default" type="checkbox" ${effectivePreset.open_by_default ? 'checked' : ''}><span>Abrir por defecto al arrancar</span></label>
        <label class="field ${isRemote ? '' : 'hidden'}"><span>Autenticación</span>
          <select data-preset="auth_type" ${selectedConfigSessionId !== 'general' ? 'disabled' : ''}>
            <option value="password" ${authType === 'password' ? 'selected' : ''}>User / Pass</option>
            <option value="key" ${authType === 'key' ? 'selected' : ''}>Public / Private key</option>
          </select>
        </label>
        <label class="field"><span>Sistema operativo target</span>${targetOsControl}</label>
        <label class="field"><span>${isDetectedLocal ? 'Terminal local detectada' : 'Shell / Target base'}</span>
          <select data-preset="shell_family" ${isDetectedLocal ? 'disabled' : ''}>${shellOptionsFor(isLocal ? 'local' : (effectivePreset.scope || 'local'), isLocal ? runtimeConfig.host_os : (effectivePreset.target_os || runtimeConfig.host_os))}</select>
        </label>
        <label class="field ${isRemote ? '' : 'hidden'}"><span>Host</span><input data-preset="host" type="text" value="${escapeHtml(effectivePreset.host || '')}"></label>
        <label class="field ${isRemote ? '' : 'hidden'}"><span>Puerto</span><input data-preset="port" type="number" value="${escapeHtml(effectivePreset.port || 22)}"></label>
        <label class="field ${isRemote ? '' : 'hidden'}"><span>Usuario</span><input data-preset="username" type="text" value="${escapeHtml(effectivePreset.username || '')}"></label>
        <label class="field ${isRemote && authType === 'key' ? '' : 'hidden'}"><span>Ruta de private key</span><input data-preset="private_key_path" type="text" value="${escapeHtml(effectivePreset.private_key_path || '')}"></label>
        <label class="check-field ${isRemote ? '' : 'hidden'}"><input data-preset="strict_host_key" type="checkbox" ${effectivePreset.strict_host_key ? 'checked' : ''}><span>Strict host key</span></label>
        <label class="field full-row ${isRemote ? 'hidden' : ''}"><span>Comando real de lanzamiento de la terminal</span><input data-preset="launch_command" type="text" value="${escapeHtml(effectivePreset.launch_command || '')}" placeholder="Ej. pwsh o wsl.exe -d Ubuntu"></label>
        <div class="full-row command-mode-note">Los comandos globales iniciales pueden definirse por texto o por fichero, pero no por ambos a la vez.</div>
        <div class="field full-row">
          <span>Modo de comandos iniciales</span>
          <div class="command-mode-group">
            <label class="check-field"><input data-preset="command_source" type="radio" name="command_source_${index}" value="text" ${showText ? 'checked' : ''}><span>Texto</span></label>
            <label class="check-field"><input data-preset="command_source" type="radio" name="command_source_${index}" value="file" ${showFile ? 'checked' : ''}><span>Fichero .command</span></label>
          </div>
        </div>
        <label class="field full-row ${showText ? '' : 'hidden'}"><span>Start command global</span><textarea data-preset="startup_command" rows="3">${escapeHtml(effectivePreset.startup_command || '')}</textarea></label>
        <label class="field full-row ${showFile ? '' : 'hidden'}"><span>Cargar fichero .command</span><input data-preset-file="command_file_content" type="file" accept=".command,.txt,text/plain"></label>
        <div class="info-inline full-row ${showFile ? '' : 'hidden'}">${effectivePreset.command_file_content ? 'Fichero .command cargado.' : 'Sin fichero .command cargado.'}</div>
      </div>
    </article>`;
}

function renderConfigPresets() {
  const presets = runtimeConfig.terminal_presets || [];
  populatePresetSelector();
  if (!presets.length) return;
  const basePreset = presets[selectedPresetIndex];
  const effectivePreset = getSessionPresetView(basePreset, selectedConfigSessionId);
  els.terminalPresetList.innerHTML = makePresetCard(basePreset, selectedPresetIndex);
  els.terminalPresetList.querySelectorAll('[data-remove-preset]').forEach((button) => {
    button.addEventListener('click', () => {
      runtimeConfig.terminal_presets.splice(Number(button.dataset.removePreset), 1);
      Object.values(runtimeConfig.session_terminal_overrides || {}).forEach((mapping) => { if (mapping && typeof mapping === 'object') delete mapping[basePreset.id]; });
      if (selectedPresetIndex >= runtimeConfig.terminal_presets.length) selectedPresetIndex = Math.max(0, runtimeConfig.terminal_presets.length - 1);
      renderConfigPresets();
    });
  });
  els.terminalPresetList.querySelectorAll('[data-clear-session-override]').forEach((button) => {
    button.addEventListener('click', () => {
      clearPresetOverrideForCurrentSession(button.dataset.clearSessionOverride || '');
      renderConfigPresets();
    });
  });
  els.terminalPresetList.querySelectorAll('[data-preset]').forEach((input) => {
    input.addEventListener('change', handlePresetInputChange);
    if (input.tagName === 'TEXTAREA' || input.type === 'text' || input.type === 'number') input.addEventListener('input', handlePresetInputChange);
  });
  els.terminalPresetList.querySelectorAll('[data-preset-file]').forEach((input) => {
    input.addEventListener('change', async () => {
      const card = input.closest('.preset-card');
      const index = Number(card.dataset.index);
      updatePresetField(index, 'command_source', 'file');
      updatePresetField(index, input.dataset.presetFile, await readFileAsText(input.files?.[0]));
      updatePresetField(index, 'startup_command', '');
      renderConfigPresets();
    });
  });
  const shellSelect = els.terminalPresetList.querySelector(`.preset-card[data-index="${selectedPresetIndex}"] [data-preset="shell_family"]`);
  if (shellSelect) shellSelect.value = effectivePreset.shell_family || firstShellIdFor((effectivePreset.scope === 'local') ? 'local' : (effectivePreset.scope || 'local'), (effectivePreset.scope === 'local') ? runtimeConfig.host_os : (effectivePreset.target_os || runtimeConfig.host_os)) || '';
}

function handlePresetInputChange(event) {
  const card = event.target.closest('.preset-card');
  const index = Number(card.dataset.index);
  const field = event.target.dataset.preset;
  if (!field) return;
  const basePreset = runtimeConfig.terminal_presets[index];
  const effectivePreset = getSessionPresetView(basePreset, selectedConfigSessionId);
  if (!basePreset) return;
  if ((field === 'scope' && basePreset.editable_scope === false) || (field === 'target_os' && (basePreset.editable_target_os === false || effectivePreset.scope === 'local')) || (field === 'shell_family' && effectivePreset.detected_local)) return;
  const value = event.target.type === 'checkbox' ? event.target.checked : event.target.value;
  updatePresetField(index, field, value);
  const updatedPreset = getSessionPresetView(basePreset, selectedConfigSessionId);
  if (field === 'scope' && selectedConfigSessionId === 'general') {
    if (value === 'local') {
      updatePresetField(index, 'auth_type', 'none');
      updatePresetField(index, 'target_os', runtimeConfig.host_os);
      basePreset.editable_target_os = false;
    } else {
      basePreset.editable_target_os = true;
    }
    ensurePresetShellSelection(updatedPreset);
    if (selectedConfigSessionId === 'general') Object.assign(basePreset, updatedPreset);
    renderConfigPresets();
    return;
  }
  if (field === 'target_os') {
    ensurePresetShellSelection(updatedPreset);
    updatePresetField(index, 'shell_family', updatedPreset.shell_family || '');
    renderConfigPresets();
    return;
  }
  if (field === 'shell_family') updatePresetField(index, 'launch_command', value || '');
  if (field === 'command_source') {
    if (value === 'text') updatePresetField(index, 'command_file_content', '');
    if (value === 'file') updatePresetField(index, 'startup_command', '');
    renderConfigPresets();
    return;
  }
  if (field === 'startup_command') {
    updatePresetField(index, 'command_source', 'text');
    updatePresetField(index, 'command_file_content', '');
  }
  if (field === 'auth_type') {
    renderConfigPresets();
    return;
  }
  const title = card.querySelector('.preset-card-head strong');
  const currentView = getSessionPresetView(basePreset, selectedConfigSessionId);
  if (field === 'name' && title) {
    title.textContent = currentView[field] || `Terminal ${index + 1}`;
    populatePresetSelector();
  }
}

function populateConfigView() {
  populateTopSessionSelectors();
  els.defaultScrollbackSelect.value = String(runtimeConfig.ui.default_scrollback || 20000);
  els.commandHistoryLimitInput.value = String(runtimeConfig.ui.command_history_limit || 50);
  els.remoteDefaultHost.value = runtimeConfig.remote_defaults.host || '';
  els.remoteDefaultPort.value = runtimeConfig.remote_defaults.port || 22;
  els.remoteDefaultUsername.value = runtimeConfig.remote_defaults.username || '';
  els.remoteDefaultKeyPath.value = runtimeConfig.remote_defaults.private_key_path || '';
  els.remoteDefaultStrictHostKey.checked = !!runtimeConfig.remote_defaults.strict_host_key;
  if (els.adminUsernameInput) els.adminUsernameInput.value = runtimeConfig.auth?.admin_username || '';
  if (els.adminPasswordInput) els.adminPasswordInput.value = '';
  (runtimeConfig.terminal_presets || []).forEach((preset) => ensurePresetShellSelection(preset));
  if (els.configActiveSessionSelect) els.configActiveSessionSelect.value = activeSessionId();
  if (els.configPresetSessionSelect) els.configPresetSessionSelect.value = selectedConfigSessionId;
  renderConfigPresets();
}

function collectConfigPayload() {
  return {
    ui: { default_scrollback: Number(els.defaultScrollbackSelect.value || 20000), command_history_limit: Number(els.commandHistoryLimitInput.value || 50) },
    remote_defaults: {
      host: els.remoteDefaultHost.value || '',
      port: Number(els.remoteDefaultPort.value || 22),
      username: els.remoteDefaultUsername.value || '',
      private_key_path: els.remoteDefaultKeyPath.value || '',
      strict_host_key: !!els.remoteDefaultStrictHostKey.checked,
    },
    active_session_id: els.configActiveSessionSelect?.value || activeSessionId(),
    terminal_sessions: sessionItems(),
    session_terminal_overrides: runtimeConfig.session_terminal_overrides || {},
    terminal_presets: (runtimeConfig.terminal_presets || []).map((preset, index) => ({
      id: preset.id || `preset-${index}`,
      name: preset.name || `Terminal ${index + 1}`,
      scope: preset.scope || 'local',
      auth_type: preset.scope === 'remote' ? (preset.auth_type || 'password') : 'none',
      target_os: preset.target_os || defaultTargetOsForScope(preset.scope || 'local'),
      shell_family: preset.shell_family || firstShellIdFor(preset.scope || 'local', preset.target_os || defaultTargetOsForScope(preset.scope || 'local')) || '',
      host: preset.host || '',
      port: Number(preset.port || 22),
      username: preset.username || '',
      private_key_path: preset.private_key_path || '',
      strict_host_key: !!preset.strict_host_key,
      startup_command: normalizeCommandSource(preset) === 'text' ? (preset.startup_command || '') : '',
      command_file_content: normalizeCommandSource(preset) === 'file' ? (preset.command_file_content || '') : '',
      launch_command: preset.launch_command || '',
      open_by_default: !!preset.open_by_default,
      detected_local: !!preset.detected_local,
    })),
  };
}

async function saveGlobalConfig() {
  els.configMessage.textContent = '';
  const response = await fetchJson('/api/config/save', { method: 'POST', body: JSON.stringify(collectConfigPayload()) });
  runtimeConfig = response.config;
  ensureScriptsArray();
  applyHistoryLimitToAllTabs();
  populateTopSessionSelectors();
  populateConfigView();
  renderScriptEditor();
  updateNewTabTargetOptions();
  syncNewTabNameWithTarget(true);
  renderNewTabCredentialFields();
  renderCredentialFields();
  renderScriptsPanel();
  els.configMessage.textContent = 'Configuración guardada.';
}

function showConfigView() {
  if (!userCan('manage_config')) return;
  els.mainView.classList.add('hidden');
  els.configView.classList.remove('hidden');
  els.adminView.classList.add('hidden');
  els.scriptsView.classList.add('hidden');
  els.dockerView.classList.add('hidden');
  els.explorerView.classList.add('hidden');
  els.schedulerView.classList.add('hidden');
  stopSchedulerPolling();
  populateConfigView();
  applyFeatureVisibility();
}

function showScriptsView() {
  if (!userCan('manage_scripts')) return;
  els.mainView.classList.add('hidden');
  els.configView.classList.add('hidden');
  els.adminView.classList.add('hidden');
  els.scriptsView.classList.remove('hidden');
  els.dockerView.classList.add('hidden');
  els.explorerView.classList.add('hidden');
  els.schedulerView.classList.add('hidden');
  stopSchedulerPolling();
  renderScriptEditor();
  applyFeatureVisibility();
}

function showMainView() {
  els.mainView.classList.remove('hidden');
  els.configView.classList.add('hidden');
  els.adminView.classList.add('hidden');
  els.scriptsView.classList.add('hidden');
  els.dockerView.classList.add('hidden');
  els.explorerView.classList.add('hidden');
  els.schedulerView.classList.add('hidden');
  stopSchedulerPolling();
  renderScriptsPanel();
  applyFeatureVisibility();
}

async function createAliasForActiveTab() {
  const tab = getActiveTab();
  const target = tab ? getTargetById(tab.targetId) : null;
  if (!tab || !target || !supportsAliases(target)) return;
  const alias_name = (els.aliasNameInput.value || '').trim();
  const command_text = (els.aliasCommandInput.value || '').trim();
  const folder = normalizeAliasFolder(els.aliasFolderInput?.value || '');
  if (!alias_name || !command_text) {
    els.aliasMessage.textContent = 'Alias y comando son obligatorios.';
    return;
  }
  els.aliasMessage.textContent = '';
  try {
    await fetchJson('/api/aliases', { method: 'POST', body: JSON.stringify({ target_id: tab.targetId, alias_name, command_text, folder, group: folder }) });
    els.aliasMessage.textContent = 'Alias guardado en Zenoterm.';
    els.aliasNameInput.value = '';
    els.aliasCommandInput.value = '';
    if (els.aliasFolderInput) els.aliasFolderInput.value = '';
    await refreshAliasList();
  } catch (error) {
    els.aliasMessage.textContent = error.message;
  }
}

function runAliasInActiveTab(command, aliasName = '') {
  const tab = getActiveTab();
  if (!tab || !command) return;
  if (injectInputIntoTab(tab, command, { execute: true })) {
    els.aliasMessage.textContent = aliasName ? `Alias lanzado: ${aliasName}` : 'Alias lanzado.';
  } else {
    els.aliasMessage.textContent = 'La pestaña no está conectada.';
  }
}

async function deleteAliasForActiveTab(aliasId, aliasName = '') {
  const tab = getActiveTab();
  if (!tab || !aliasId) return;
  try {
    await fetchJson(`/api/aliases/${encodeURIComponent(aliasId)}?target_id=${encodeURIComponent(tab.targetId)}`, { method: 'DELETE' });
    els.aliasMessage.textContent = aliasName ? `Alias borrado: ${aliasName}` : 'Alias borrado.';
    await refreshAliasList();
  } catch (error) {
    els.aliasMessage.textContent = error.message;
  }
}

let staticEventsBound = false;
let appEventsBound = false;

function dockerContainerFilterValue() {
  return (els.dockerSearchInput?.value || '').trim().toLowerCase();
}

function dockerContainerStateFilterValue() {
  return String(els.dockerStateFilterSelect?.value || 'all').trim().toLowerCase();
}

function matchesDockerStateFilter(item, stateFilter) {
  if (!stateFilter || stateFilter === 'all') return true;
  const state = String(item.state || '').trim().toLowerCase();
  const statusText = String(item.status_text || '').trim().toLowerCase();
  if (stateFilter === 'running') return !!item.running;
  if (stateFilter === 'stopped') return !item.running;
  if (stateFilter === 'healthy') return statusText.includes('healthy') && !statusText.includes('unhealthy');
  if (stateFilter === 'unhealthy') return statusText.includes('unhealthy');
  return state === stateFilter || statusText.startsWith(`${stateFilter} `) || statusText === stateFilter;
}

function filteredDockerContainers() {
  const filter = dockerContainerFilterValue();
  const stateFilter = dockerContainerStateFilterValue();
  const showStopped = !!els.dockerShowStoppedCheckbox?.checked;
  return dockerContainers().filter((item) => {
    if (!showStopped && !item.running) return false;
    if (!matchesDockerStateFilter(item, stateFilter)) return false;
    if (!filter) return true;
    const haystack = [item.name, item.image, item.compose_project, item.compose_service, item.state, item.status_text].join(' ').toLowerCase();
    return haystack.includes(filter);
  });
}

function populateDockerGroupSelector() {
  ensureDockerStore();
  const groups = dockerGroups();
  const hasSelectedSaved = !!selectedDockerGroupId && groups.some((item) => item.id === selectedDockerGroupId);
  if (!hasSelectedSaved) selectedDockerGroupId = '';
  if (els.dockerGroupSelect) {
    const options = ['<option value="">Nuevo grupo sin guardar</option>', ...groups.map((group) => `<option value="${escapeHtml(group.id)}">${escapeHtml(group.name || 'Grupo sin nombre')}</option>`)].join('');
    els.dockerGroupSelect.innerHTML = options;
    els.dockerGroupSelect.value = selectedDockerGroupId || '';
  }
}

function currentDockerGroup() {
  ensureDockerStore();
  const groups = dockerGroups();
  const selectedSaved = groups.find((item) => item.id === selectedDockerGroupId);
  if (selectedSaved) {
    dockerDraftGroup = null;
    return selectedSaved;
  }
  if (!dockerDraftGroup) dockerDraftGroup = newEmptyDockerGroup();
  return dockerDraftGroup;
}

function persistCurrentDockerGroupIfNeeded() {
  const group = currentDockerGroup();
  if (!group) return null;
  const groups = dockerGroups();
  if (groups.some((item) => item.id === group.id)) return group;
  runtimeConfig.docker_management.groups = [...groups, group];
  dockerDraftGroup = null;
  selectedDockerGroupId = group.id;
  return group;
}

function syncDockerGroupFormFromState() {
  const group = currentDockerGroup();
  populateDockerGroupSelector();
  if (els.dockerGroupNameInput) els.dockerGroupNameInput.value = group?.name || '';
  if (els.dockerGroupDescriptionInput) els.dockerGroupDescriptionInput.value = group?.description || '';
  if (els.dockerGroupDefaultModeSelect) els.dockerGroupDefaultModeSelect.value = group?.default_run_mode || 'normal';
  if (els.dockerDeleteGroupBtn) els.dockerDeleteGroupBtn.textContent = selectedDockerGroupId ? 'Eliminar grupo' : 'Descartar borrador';
  renderDockerGroupEntries();
  renderDockerGroupsList();
}

function syncDockerGroupStateFromForm() {
  const group = currentDockerGroup();
  if (!group) return;
  group.name = (els.dockerGroupNameInput?.value || '').trim();
  group.description = (els.dockerGroupDescriptionInput?.value || '').trim();
  group.default_run_mode = els.dockerGroupDefaultModeSelect?.value || 'normal';
}

function dockerContainerOptionsHtml(selectedValue = '') {
  return dockerContainers().map((item) => `<option value="${escapeHtml(item.id)}" ${item.id === selectedValue ? 'selected' : ''}>${escapeHtml(item.name)}${item.compose_project ? ` · ${escapeHtml(item.compose_project)}` : ''}</option>`).join('');
}

function renderDockerGroupEntries() {
  const group = currentDockerGroup();
  if (!els.dockerGroupEntries) return;
  const entries = Array.isArray(group?.entries) ? group.entries : [];
  const rows = entries.map((entry, index) => `
    <div class="docker-group-entry-row" data-entry-index="${index}">
      <label class="field compact-field">
        <span>Contenedor</span>
        <select data-docker-entry-field="container_id">${dockerContainerOptionsHtml(entry.container_id)}</select>
      </label>
      <label class="field compact-field docker-order-field">
        <span>Orden</span>
        <input data-docker-entry-field="order" type="number" min="1" value="${Number(entry.order || index + 1)}">
      </label>
      <button type="button" class="mini-btn danger-btn" data-docker-entry-remove="${index}">Quitar</button>
    </div>`).join('');
  els.dockerGroupEntries.innerHTML = `
    <div class="docker-group-entries-head">
      <button type="button" class="config-action-btn" id="dockerAddEntryBtn">Añadir contenedor al grupo</button>
    </div>
    ${rows || '<div class="docker-empty-state">Este grupo todavía no tiene contenedores. Añade uno desde aquí o desde el inventario.</div>'}`;
  els.dockerGroupEntries.querySelector('#dockerAddEntryBtn')?.addEventListener('click', () => {
    const first = dockerContainers()[0];
    if (!first) {
      setDockerMessage('No hay contenedores disponibles para añadir.');
      return;
    }
    const nextOrder = Math.max(0, ...((group.entries || []).map((item) => Number(item.order || 0)))) + 1;
    group.entries = [...(group.entries || []), {
      container_id: first.id,
      name: first.name,
      image: first.image,
      order: nextOrder,
      compose_project: first.compose_project || '',
      compose_service: first.compose_service || '',
      compose_working_dir: first.compose_working_dir || '',
      compose_files: first.compose_files || [],
      stack_key: first.stack_key || '',
    }];
    renderDockerGroupEntries();
    renderDockerGroupsList();
  });
  els.dockerGroupEntries.querySelectorAll('[data-docker-entry-remove]').forEach((button) => {
    button.addEventListener('click', () => {
      const removeIndex = Number(button.dataset.dockerEntryRemove || -1);
      group.entries.splice(removeIndex, 1);
      renderDockerGroupEntries();
      renderDockerGroupsList();
    });
  });
  els.dockerGroupEntries.querySelectorAll('[data-docker-entry-field]').forEach((input) => {
    input.addEventListener('change', () => {
      const row = input.closest('[data-entry-index]');
      const index = Number(row?.dataset.entryIndex || -1);
      if (index < 0) return;
      const entry = group.entries[index];
      if (!entry) return;
      const field = input.dataset.dockerEntryField;
      if (field === 'container_id') {
        const container = dockerContainers().find((item) => item.id === input.value);
        if (!container) return;
        entry.container_id = container.id;
        entry.name = container.name;
        entry.image = container.image;
        entry.compose_project = container.compose_project || '';
        entry.compose_service = container.compose_service || '';
        entry.compose_working_dir = container.compose_working_dir || '';
        entry.compose_files = container.compose_files || [];
        entry.stack_key = container.stack_key || '';
      } else if (field === 'order') {
        entry.order = Math.max(1, Number(input.value || 1));
      }
      renderDockerGroupsList();
    });
  });
}

function renderDockerStatusCards() {
  ensureDockerStore();
  if (!els.dockerStatusCards) return;
  const engine = runtimeConfig.docker_management.engine || {};
  const containers = dockerContainers();
  const stackCount = new Set(containers.map((item) => (item.compose_project || '').trim()).filter(Boolean)).size;
  const contextLabel = engine.context && !String(engine.context).startsWith('socket:')
    ? engine.context
    : (engine.connection_mode === 'socket' ? 'socket local' : 'default');
  const contextDetail = engine.socket_path || engine.docker_host || engine.context || 'default';
  const engineDetail = [
    engine.server_version ? `Engine ${engine.server_version}` : '',
    engine.connection_mode ? engine.connection_mode.toUpperCase() : '',
    contextLabel ? `ctx ${contextLabel}` : '',
  ].filter(Boolean).join(' · ');
  const cards = [
    { label: 'Docker Engine', value: engine.connected ? 'Conectado' : (engine.available ? 'Sin conexión' : 'No disponible'), detail: engineDetail || engine.message || '', tone: engine.connected ? 'ok' : 'warn' },
    { label: 'Contenedores running', value: String(runtimeConfig.docker_management.running_count || 0), detail: 'Disponibles para terminal Docker', tone: 'info' },
    { label: 'Contenedores detenidos', value: String(runtimeConfig.docker_management.stopped_count || 0), detail: 'Puedes incluirlos en grupos o arrancarlos', tone: 'muted' },
    { label: 'Stacks detectados', value: String(stackCount), detail: contextDetail, tone: 'muted' },
  ];
  els.dockerStatusCards.innerHTML = cards.map((card) => `<article class="docker-status-card tone-${escapeHtml(card.tone)}"><span>${escapeHtml(card.label)}</span><strong>${escapeHtml(card.value)}</strong><small>${escapeHtml(card.detail || '')}</small></article>`).join('');
}

function renderDockerContainers() {
  if (!els.dockerContainersList) return;
  const items = filteredDockerContainers();
  if (!items.length) {
    const total = dockerContainers().length;
    const filter = dockerContainerFilterValue();
    const stateFilter = dockerContainerStateFilterValue();
    const engine = runtimeConfig.docker_management.engine || {};
    let message = 'No hay contenedores que coincidan con el filtro actual. Revisa la detección o cambia el filtro.';
    if (!total && engine.connected) {
      message = `El engine Docker responde, pero el contexto activo (${escapeHtml(engine.context || engine.docker_host || 'default')}) no ha devuelto contenedores.`;
    } else if (!total && !engine.connected) {
      message = 'Docker no está conectado en este host, así que no se puede construir el inventario.';
    } else if (!filter && stateFilter !== 'all') {
      message = `No hay contenedores que coincidan con el estado ${escapeHtml(stateFilter)} en este contexto.`;
    } else if (!filter && !els.dockerShowStoppedCheckbox?.checked) {
      message = 'No hay contenedores running en este contexto. Activa también los detenidos para ver el resto del inventario.';
    }
    els.dockerContainersList.innerHTML = `<div class="docker-empty-state">${message}</div>`;
    return;
  }
  els.dockerContainersList.innerHTML = items.map((item) => `
    <article class="docker-card ${item.running ? 'is-running' : 'is-stopped'}">
      <div class="docker-card-head">
        <div class="docker-card-title">
          <strong>${escapeHtml(item.name)}</strong>
          <span class="docker-subline">${escapeHtml(item.image)}</span>
          <span class="docker-subline">${escapeHtml(item.status_text || item.state || '')}</span>
        </div>
        <span class="docker-badge ${item.running ? 'is-running' : 'is-stopped'}">${escapeHtml(item.running ? 'running' : (item.state || 'stopped'))}</span>
      </div>
      <div class="docker-meta-grid">
        <div class="docker-meta-item"><b>Stack</b><span>${escapeHtml(item.compose_project || 'Manual')}</span></div>
        <div class="docker-meta-item"><b>Servicio</b><span>${escapeHtml(item.compose_service || 'N/D')}</span></div>
        <div class="docker-meta-item"><b>Puertos</b><span>${escapeHtml((item.ports || []).join(', ') || 'N/D')}</span></div>
        <div class="docker-meta-item"><b>Shell</b><span>${escapeHtml(item.shell_family || 'auto')}</span></div>
      </div>
      <div class="docker-actions-row">
        <button type="button" class="mini-btn" data-docker-action="terminal" data-container-id="${escapeHtml(item.id)}">Terminal</button>
        <button type="button" class="mini-btn" data-docker-action="group" data-container-id="${escapeHtml(item.id)}">Añadir al grupo</button>
        <button type="button" class="mini-btn" data-docker-action="logs" data-container-id="${escapeHtml(item.id)}">Logs</button>
        <button type="button" class="mini-btn" data-docker-action="pull" data-container-id="${escapeHtml(item.id)}">Pull</button>
        <button type="button" class="mini-btn" data-docker-action="${item.running ? 'restart' : 'start'}" data-container-id="${escapeHtml(item.id)}">${item.running ? 'Restart' : 'Start'}</button>
        ${item.running ? `<button type="button" class="mini-btn danger-btn" data-docker-action="stop" data-container-id="${escapeHtml(item.id)}">Stop</button>` : ''}
      </div>
    </article>`).join('');
  els.dockerContainersList.querySelectorAll('[data-docker-action]').forEach((button) => {
    button.addEventListener('click', async () => {
      const containerId = button.dataset.containerId || '';
      const action = button.dataset.dockerAction || '';
      const container = dockerContainers().find((item) => item.id === containerId);
      if (!container) return;
      if (action === 'group') {
        const group = currentDockerGroup();
        const exists = (group.entries || []).some((entry) => entry.container_id === container.id);
        if (!exists) {
          group.entries = [...(group.entries || []), {
            container_id: container.id,
            name: container.name,
            image: container.image,
            order: (group.entries || []).length + 1,
            compose_project: container.compose_project || '',
            compose_service: container.compose_service || '',
            compose_working_dir: container.compose_working_dir || '',
            compose_files: container.compose_files || [],
            stack_key: container.stack_key || '',
          }];
          renderDockerGroupEntries();
          renderDockerGroupsList();
          setDockerMessage(`Añadido al grupo: ${container.name}`);
        }
        return;
      }
      if (action === 'terminal') {
        await refreshDockerOverview({ silent: true });
        const target = (runtimeConfig.targets || []).find((item) => item.connection_scope === 'docker' && item.docker_container_id === container.id);
        if (!target) {
          setDockerMessage('Ese contenedor no está running ahora mismo, así que no puede abrirse una terminal Docker.');
          return;
        }
        const tab = createTab({ title: target.label, targetId: target.id, scrollback: Number(runtimeConfig.ui.default_scrollback || 20000), credentials: {} });
        openSocketForTab(tab, 'start');
        showMainView();
        return;
      }
      if (action === 'logs') {
        const response = await fetchJson(`/api/docker/container/logs?container_id=${encodeURIComponent(container.id)}`);
        window.alert(response.logs || `No hay logs para ${container.name}`);
        return;
      }
      await dockerContainerAction(container, action);
    });
  });
}

async function dockerContainerAction(container, action) {
  const response = await fetchJson('/api/docker/container/action', { method: 'POST', body: JSON.stringify({ container_id: container.id, container_name: container.name, action }) });
  runtimeConfig = response.config;
  ensureScriptsArray();
  ensureDockerStore();
  renderDockerManagement();
  updateNewTabTargetOptions();
  setDockerMessage(response.ok ? `Acción ejecutada: ${action} sobre ${container.name}` : (response.stderr || response.stdout || `No se pudo ejecutar ${action}.`));
}

function renderDockerGroupsList() {
  if (!els.dockerGroupsList) return;
  const groups = dockerGroups();
  if (!groups.length) {
    els.dockerGroupsList.innerHTML = '<div class="docker-empty-state">Todavía no hay grupos guardados. Puedes preparar uno en el panel derecho y guardarlo cuando esté listo.</div>';
    return;
  }
  els.dockerGroupsList.innerHTML = groups.map((group) => `
    <article class="docker-group-card ${group.id === selectedDockerGroupId ? 'is-selected' : ''}">
      <div class="docker-card-head">
        <div class="docker-card-title">
          <strong>${escapeHtml(group.name || 'Grupo sin nombre')}</strong>
          <span class="docker-subline">${escapeHtml(group.description || 'Sin descripción')}</span>
          <span class="docker-subline">${escapeHtml(`${(group.entries || []).length} contenedor(es)`)} </span>
        </div>
        <span class="docker-badge">${escapeHtml(group.default_run_mode || 'normal')}</span>
      </div>
      <div class="docker-group-list-inline">${(group.entries || []).map((entry) => `<span>${escapeHtml(`#${entry.order} ${entry.name || entry.container_id}`)}</span>`).join('') || '<span>Sin contenedores</span>'}</div>
      <div class="docker-actions-row">
        <button type="button" class="mini-btn" data-docker-group-action="edit" data-group-id="${escapeHtml(group.id)}">Editar</button>
        <button type="button" class="mini-btn" data-docker-group-action="run" data-group-id="${escapeHtml(group.id)}">Play</button>
        <button type="button" class="mini-btn" data-docker-group-action="pull" data-group-id="${escapeHtml(group.id)}">Play + Pull</button>
        <button type="button" class="mini-btn" data-docker-group-action="force-recreate" data-group-id="${escapeHtml(group.id)}">Play + Force</button>
        <button type="button" class="mini-btn" data-docker-group-action="pull-force-recreate" data-group-id="${escapeHtml(group.id)}">Pull + Force</button>
      </div>
    </article>`).join('');
  els.dockerGroupsList.querySelectorAll('[data-docker-group-action]').forEach((button) => {
    button.addEventListener('click', async () => {
      const groupId = button.dataset.groupId || '';
      const action = button.dataset.dockerGroupAction || '';
      if (action === 'edit') {
        selectedDockerGroupId = groupId;
        syncDockerGroupFormFromState();
        return;
      }
      await runDockerGroup(groupId, action === 'run' ? '' : action);
    });
  });
}

async function runDockerGroup(groupId, runMode = '') {
  const response = await fetchJson('/api/docker/groups/run', { method: 'POST', body: JSON.stringify({ group_id: groupId, run_mode: runMode }) });
  runtimeConfig = response.config;
  ensureScriptsArray();
  ensureDockerStore();
  renderDockerManagement();
  updateNewTabTargetOptions();
  const failed = (response.logs || []).filter((item) => !item.ok).length;
  setDockerMessage(failed ? `Grupo ejecutado con incidencias (${failed} comandos fallaron).` : `Grupo ejecutado correctamente: ${response.group?.name || groupId}`);
}

async function saveDockerGroups() {
  syncDockerGroupStateFromForm();
  const group = currentDockerGroup();
  if (!group.name && !(group.entries || []).length && !selectedDockerGroupId) {
    setDockerMessage('No hay cambios de grupo para guardar.');
    return;
  }
  const persisted = persistCurrentDockerGroupIfNeeded();
  const response = await fetchJson('/api/docker/groups/save', { method: 'POST', body: JSON.stringify({ groups: dockerGroups() }) });
  runtimeConfig = response.config;
  ensureScriptsArray();
  ensureDockerStore();
  if (persisted) selectedDockerGroupId = persisted.id;
  renderDockerManagement();
  setDockerMessage('Grupos Docker guardados.');
}

async function generateDockerGroupScript() {
  syncDockerGroupStateFromForm();
  const group = currentDockerGroup();
  if (!group.name) {
    setDockerMessage('Ponle nombre al grupo antes de generar el script.');
    return;
  }
  await saveDockerGroups();
  const response = await fetchJson('/api/docker/groups/generate-script', { method: 'POST', body: JSON.stringify({ group_id: selectedDockerGroupId || currentDockerGroup().id, import_to_app: true }) });
  runtimeConfig = response.config;
  ensureScriptsArray();
  ensureDockerStore();
  renderDockerManagement();
  renderScriptEditor();
  renderScriptsPanel();
  setDockerMessage(`Script generado e importado: ${response.script_name}`);
}

function renderDockerManagement() {
  ensureDockerStore();
  renderDockerStatusCards();
  populateDockerGroupSelector();
  syncDockerGroupFormFromState();
  renderDockerContainers();
}

function showDockerView() {
  if (!userCan('use_docker')) return;
  els.mainView.classList.add('hidden');
  els.configView.classList.add('hidden');
  els.adminView.classList.add('hidden');
  els.scriptsView.classList.add('hidden');
  els.explorerView.classList.add('hidden');
  els.schedulerView.classList.add('hidden');
  els.dockerView.classList.remove('hidden');
  stopSchedulerPolling();
  refreshDockerOverview({ silent: false }).catch(() => renderDockerManagement());
  applyFeatureVisibility();
}




function setExplorerMessage(message = '') { if (els.explorerMessage) els.explorerMessage.textContent = message; }

function explorerFilteredEntries() {
  const needle = String(explorerState.filter || '').trim().toLowerCase();
  if (!needle) return explorerState.entries || [];
  return (explorerState.entries || []).filter((item) => String(item.name || '').toLowerCase().includes(needle));
}

function updateExplorerClipboardInfo() {
  if (!els.explorerClipboardInfo) return;
  const clip = explorerState.clipboard;
  els.explorerClipboardInfo.textContent = clip ? `${clip.mode === 'cut' ? 'Cortar' : 'Copiar'} · ${clip.name}` : 'Vacío';
}

function hideExplorerContextMenu() { if (explorerContextMenu) { explorerContextMenu.remove(); explorerContextMenu = null; } }

function explorerDownloadUrl(path) { return `/api/explorer/download?path=${encodeURIComponent(path || '')}`; }

async function loadExplorerPath(path = '') {
  const response = await fetchJson(`/api/explorer/list?path=${encodeURIComponent(path || explorerState.currentPath || '')}`);
  explorerState.currentPath = response.path || path || '';
  explorerState.entries = Array.isArray(response.entries) ? response.entries : [];
  explorerState.breadcrumbs = Array.isArray(response.breadcrumbs) ? response.breadcrumbs : [];
  explorerState.permission = response.permission || { access: 'read_only', can_write: false };
  if (els.explorerPathInput) els.explorerPathInput.value = explorerState.currentPath || '';
  if (els.explorerStats) els.explorerStats.textContent = `${explorerState.entries.length} elemento(s) · ${explorerCanWriteCurrentDir() ? 'lectura / escritura' : 'solo lectura'}`;
  renderExplorerBreadcrumbs();
  renderExplorerList();
  applyExplorerPermissionUi();
  setExplorerMessage(`Ruta cargada: ${explorerState.currentPath}`);
}

function renderExplorerBreadcrumbs() {
  if (!els.explorerBreadcrumbs) return;
  els.explorerBreadcrumbs.innerHTML = (explorerState.breadcrumbs || []).map((item) => `<button type="button" class="explorer-breadcrumb" data-path="${escapeHtml(item.path || '')}">${escapeHtml(item.label || item.path || '')}</button>`).join('');
  els.explorerBreadcrumbs.querySelectorAll('[data-path]').forEach((button) => button.addEventListener('click', () => loadExplorerPath(button.dataset.path || '').catch((error) => setExplorerMessage(error.message || 'No se pudo abrir la ruta.'))));
}

function renderExplorerPreview() {
  const file = explorerState.openedFile;
  const isMarkdown = file && file.preview_mode === 'markdown';
  if (els.explorerPreviewTitle) els.explorerPreviewTitle.textContent = file ? file.name || 'Vista previa' : 'Vista previa';
  if (els.explorerPreviewMeta) els.explorerPreviewMeta.textContent = file ? `${file.path || ''} · ${file.language || 'text'} · ${file?.permission?.can_write ? 'lectura / escritura' : 'solo lectura'}` : 'Selecciona un archivo de texto o markdown.';
  els.explorerPreviewEmpty?.classList.toggle('hidden', !!file);
  els.explorerPreviewTabs?.classList.toggle('hidden', !isMarkdown || !file);
  els.explorerEditorHost?.classList.toggle('hidden', !file || (isMarkdown && explorerState.renderedMode === 'render'));
  els.explorerMarkdownHost?.classList.toggle('hidden', !file || !isMarkdown || explorerState.renderedMode !== 'render');
  if (!file) {
    applyExplorerPermissionUi();
    return;
  }
  if (els.explorerEditor && els.explorerEditor.value !== file.content) els.explorerEditor.value = file.content || '';
  refreshExplorerHighlight();
  if (isMarkdown && els.explorerMarkdownHost && typeof marked !== 'undefined') {
    els.explorerMarkdownHost.innerHTML = marked.parse(file.content || '');
    if (typeof hljs !== 'undefined') els.explorerMarkdownHost.querySelectorAll('pre code').forEach((block) => hljs.highlightElement(block));
  }
  els.explorerSourceTabBtn?.classList.toggle('is-active', explorerState.renderedMode !== 'render');
  els.explorerRenderedTabBtn?.classList.toggle('is-active', explorerState.renderedMode === 'render');
  applyExplorerPermissionUi();
}

function refreshExplorerHighlight() {
  if (!els.explorerHighlightCode || !els.explorerEditor) return;
  const file = explorerState.openedFile;
  const code = els.explorerEditor.value || '';
  let html = escapeHtml(code);
  if (typeof hljs !== 'undefined') {
    try {
      if (file?.language && hljs.getLanguage(file.language)) html = hljs.highlight(code, { language: file.language }).value;
      else html = hljs.highlightAuto(code).value;
    } catch {}
  }
  els.explorerHighlightCode.innerHTML = html + '\n';
  els.explorerHighlight.scrollTop = els.explorerEditor.scrollTop;
  els.explorerHighlight.scrollLeft = els.explorerEditor.scrollLeft;
  if (explorerState.openedFile) explorerState.openedFile.content = code;
}

function renderExplorerList() {
  if (!els.explorerList) return;
  const items = explorerFilteredEntries();
  if (!items.length) {
    els.explorerList.innerHTML = '<div class="explorer-empty-state">No hay elementos en esta carpeta o no coinciden con el filtro.</div>';
    return;
  }
  const parentPath = explorerState.breadcrumbs.length > 1 ? explorerState.breadcrumbs[explorerState.breadcrumbs.length - 2].path : '';
  const rows = [];
  if (parentPath) rows.push(`<div class="explorer-row is-directory" data-path="${escapeHtml(parentPath)}" data-dir="1"><div class="explorer-row-icon">↩</div><div class="explorer-row-name">..</div><div class="explorer-row-meta">Carpeta superior</div><div class="explorer-row-meta extra">-</div><div class="explorer-row-meta extra">-</div></div>`);
  items.forEach((item) => {
    const selected = explorerState.selectedPath && explorerState.selectedPath === item.path ? ' is-selected' : '';
    rows.push(`<div class="explorer-row ${item.is_dir ? 'is-directory' : 'is-file'}${selected}" data-path="${escapeHtml(item.path)}" data-dir="${item.is_dir ? '1' : '0'}" draggable="${item.draggable_download ? 'true' : 'false'}">
      <div class="explorer-row-icon">${item.is_dir ? '📁' : (item.preview_mode === 'markdown' ? '📝' : '📄')}</div>
      <div class="explorer-row-name" title="${escapeHtml(item.name || '')}">${escapeHtml(item.name || '')}</div>
      <div class="explorer-row-meta">${escapeHtml(item.is_dir ? 'Carpeta' : (item.language || 'Archivo'))}</div>
      <div class="explorer-row-meta extra">${escapeHtml(item.size_label || '-')}</div>
      <div class="explorer-row-meta extra">${escapeHtml(item.modified_label || '-')}</div>
    </div>`);
  });
  els.explorerList.innerHTML = rows.join('');
  els.explorerList.querySelectorAll('.explorer-row').forEach((row) => {
    row.addEventListener('click', () => { explorerState.selectedPath = row.dataset.path || ''; renderExplorerList(); });
    row.addEventListener('dblclick', async () => {
      const path = row.dataset.path || '';
      const isDir = row.dataset.dir === '1';
      if (isDir) await loadExplorerPath(path);
      else await openExplorerFile(path);
    });
    row.addEventListener('contextmenu', (event) => { event.preventDefault(); explorerState.selectedPath = row.dataset.path || ''; renderExplorerList(); showExplorerContextMenu(event.clientX, event.clientY, row.dataset.path || '', row.dataset.dir === '1'); });
    row.addEventListener('dragstart', (event) => {
      const path = row.dataset.path || '';
      const isDir = row.dataset.dir === '1';
      const name = path.split(/[\/]/).pop() || 'download';
      event.dataTransfer.effectAllowed = isDir ? 'move' : 'copyMove';
      event.dataTransfer.setData('text/plain', path);
      event.dataTransfer.setData('application/x-zenoterm-path', path);
      if (!isDir) event.dataTransfer.setData('DownloadURL', `application/octet-stream:${name}:${window.location.origin}${explorerDownloadUrl(path)}`);
    });
    row.addEventListener('dragover', (event) => { if (row.dataset.dir === '1' && explorerCanWriteCurrentDir()) event.preventDefault(); });
    row.addEventListener('drop', async (event) => {
      if (row.dataset.dir !== '1' || !explorerCanWriteCurrentDir()) return;
      event.preventDefault();
      const sourcePath = event.dataTransfer.getData('application/x-zenoterm-path') || event.dataTransfer.getData('text/plain');
      if (!sourcePath || sourcePath === row.dataset.path) return;
      const move = event.ctrlKey ? false : true;
      const endpoint = move ? '/api/explorer/move' : '/api/explorer/copy';
      try {
        const response = await fetchJson(endpoint, { method: 'POST', body: JSON.stringify({ source_path: sourcePath, destination_dir: row.dataset.path, overwrite: false }) });
        setExplorerMessage(response.message || (move ? 'Movido.' : 'Copiado.'));
        await loadExplorerPath(explorerState.currentPath);
      } catch (error) { setExplorerMessage(error.message || 'No se pudo completar el drag & drop.'); }
    });
  });
}

async function openExplorerFile(path) {
  const response = await fetchJson(`/api/explorer/read-text?path=${encodeURIComponent(path || '')}`);
  explorerState.openedFile = response;
  explorerState.openedFile.permission = response.permission || { access: 'read_only', can_write: false };
  explorerState.renderedMode = response.preview_mode === 'markdown' ? 'render' : 'source';
  renderExplorerPreview();
  setExplorerMessage(`Archivo abierto: ${response.name}`);
}

async function saveExplorerFile() {
  if (!explorerState.openedFile) return;
  if (!explorerCanWriteOpenedFile()) { setExplorerMessage('Este archivo está en modo solo lectura para este usuario.'); return; }
  const response = await fetchJson('/api/explorer/save-text', { method: 'POST', body: JSON.stringify({ path: explorerState.openedFile.path, content: els.explorerEditor?.value || '' }) });
  setExplorerMessage(response.message || 'Archivo guardado.');
  await loadExplorerPath(explorerState.currentPath);
}

function showExplorerContextMenu(x, y, path, isDir) {
  hideExplorerContextMenu();
  const menu = document.createElement('div');
  menu.className = 'explorer-context-menu';
  const writable = explorerCanWriteCurrentDir();
  const actions = writable
    ? [
        { id: 'open', label: isDir ? 'Abrir carpeta' : 'Abrir archivo' },
        { id: 'copy', label: 'Copiar' },
        { id: 'cut', label: 'Cortar' },
        { id: 'rename', label: 'Renombrar' },
        { id: 'download', label: isDir ? 'Descargar zip' : 'Descargar' },
        { id: 'delete', label: 'Eliminar', danger: true },
      ]
    : [
        { id: 'open', label: isDir ? 'Abrir carpeta' : 'Abrir archivo' },
        { id: 'download', label: isDir ? 'Descargar zip' : 'Descargar' },
      ];
  menu.innerHTML = actions.map((item) => `<button type="button" data-action="${item.id}" class="${item.danger ? 'danger' : ''}">${item.label}</button>`).join('');
  menu.style.left = `${x}px`;
  menu.style.top = `${y}px`;
  document.body.appendChild(menu);
  explorerContextMenu = menu;
  menu.querySelectorAll('button').forEach((button) => button.addEventListener('click', async () => {
    const action = button.dataset.action || '';
    hideExplorerContextMenu();
    const name = path.split(/[\/]/).pop() || path;
    try {
      if (action === 'open') { if (isDir) await loadExplorerPath(path); else await openExplorerFile(path); }
      if (action === 'copy' || action === 'cut') { explorerState.clipboard = { mode: action, path, name }; updateExplorerClipboardInfo(); applyExplorerPermissionUi(); setExplorerMessage(`Preparado para ${action === 'cut' ? 'mover' : 'copiar'}: ${name}`); }
      if (action === 'rename') { const newName = window.prompt('Nuevo nombre', name); if (newName) { const response = await fetchJson('/api/explorer/rename', { method: 'POST', body: JSON.stringify({ path, new_name: newName }) }); setExplorerMessage(response.message || 'Renombrado.'); await loadExplorerPath(explorerState.currentPath); } }
      if (action === 'download') window.open(explorerDownloadUrl(path), '_blank');
      if (action === 'delete') { if (window.confirm(`¿Eliminar ${name}?`)) { const response = await fetchJson('/api/explorer/delete', { method: 'POST', body: JSON.stringify({ path }) }); setExplorerMessage(response.message || 'Eliminado.'); if (explorerState.openedFile?.path === path) explorerState.openedFile = null; renderExplorerPreview(); await loadExplorerPath(explorerState.currentPath); } }
    } catch (error) { setExplorerMessage(error.message || 'No se pudo completar la acción.'); }
  }));
}

async function explorerPasteClipboard() {
  if (!explorerCanWriteCurrentDir()) { setExplorerMessage('Esta ruta está en modo solo lectura para este usuario.'); return; }
  const clip = explorerState.clipboard;
  if (!clip) { setExplorerMessage('El portapapeles del Explorer está vacío.'); return; }
  const endpoint = clip.mode === 'cut' ? '/api/explorer/move' : '/api/explorer/copy';
  const response = await fetchJson(endpoint, { method: 'POST', body: JSON.stringify({ source_path: clip.path, destination_dir: explorerState.currentPath, overwrite: false }) });
  setExplorerMessage(response.message || 'Pegado completado.');
  if (clip.mode === 'cut') explorerState.clipboard = null;
  updateExplorerClipboardInfo();
  applyExplorerPermissionUi();
  await loadExplorerPath(explorerState.currentPath);
}

async function explorerUploadFiles(fileList) {
  if (!explorerCanWriteCurrentDir()) { setExplorerMessage('Esta ruta está en modo solo lectura para este usuario.'); return; }
  if (!fileList || !fileList.length) { setExplorerMessage('No se seleccionó ningún archivo.'); return; }
  const form = new FormData();
  form.append('path', explorerState.currentPath || '');
  form.append('overwrite', 'false');
  Array.from(fileList).forEach((file) => form.append('files', file, file.webkitRelativePath || file.name));
  const response = await fetch('/api/explorer/upload', { method: 'POST', credentials: 'include', body: form });
  const data = await response.json();
  if (!response.ok || !data.ok) throw new Error(data.message || 'No se pudo subir.');
  setExplorerMessage(data.message || 'Subida completada.');
  await loadExplorerPath(explorerState.currentPath);
}

function initExplorerSplitResize() {
  const divider = els.explorerDivider;
  const split = els.explorerSplit;
  if (!divider || !split || divider.dataset.bound === '1') return;
  divider.dataset.bound = '1';
  let active = false;
  const move = (event) => {
    if (!active) return;
    const rect = split.getBoundingClientRect();
    const pct = Math.max(25, Math.min(75, ((event.clientX - rect.left) / rect.width) * 100));
    split.style.setProperty('--left-pane-width', `${pct}%`);
  };
  divider.addEventListener('mousedown', () => { active = true; document.body.style.cursor = 'col-resize'; });
  window.addEventListener('mousemove', move);
  window.addEventListener('mouseup', () => { active = false; document.body.style.cursor = ''; });
}


function schedulerTaskCategories() {
  return [...new Set(schedulerTasks().map((item) => String(item.category || 'General')).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'es'));
}

function schedulerTaskSubcategories(category = '') {
  return [...new Set(schedulerTasks().filter((item) => !category || String(item.category || 'General') === category).map((item) => String(item.subcategory || 'General')).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'es'));
}

function populateSchedulerFilters() {
  const currentCategory = els.schedulerCategoryFilterSelect?.value || '';
  const currentSubcategory = els.schedulerSubcategoryFilterSelect?.value || '';
  const categories = schedulerTaskCategories();
  if (els.schedulerCategoryFilterSelect) {
    els.schedulerCategoryFilterSelect.innerHTML = `<option value="">Todas</option>${categories.map((item) => `<option value="${escapeHtml(item)}" ${item === currentCategory ? 'selected' : ''}>${escapeHtml(item)}</option>`).join('')}`;
    if (currentCategory && !categories.includes(currentCategory)) els.schedulerCategoryFilterSelect.value = '';
  }
  const selectedCategory = els.schedulerCategoryFilterSelect?.value || '';
  const subcategories = schedulerTaskSubcategories(selectedCategory);
  if (els.schedulerSubcategoryFilterSelect) {
    els.schedulerSubcategoryFilterSelect.innerHTML = `<option value="">Todas</option>${subcategories.map((item) => `<option value="${escapeHtml(item)}" ${item === currentSubcategory ? 'selected' : ''}>${escapeHtml(item)}</option>`).join('')}`;
    if (currentSubcategory && !subcategories.includes(currentSubcategory)) els.schedulerSubcategoryFilterSelect.value = '';
  }
}

function renderSchedulerStatusCards() {
  const stats = schedulerStats();
  if (!els.schedulerStatusCards) return;
  const cards = [
    { label: 'Tareas activas', value: String(stats.enabled_count || 0), detail: 'Programaciones habilitadas', tone: 'ok' },
    { label: 'Ejecuciones en curso', value: String(stats.running_count || 0), detail: 'Procesos vivos ahora mismo', tone: stats.running_count ? 'info' : 'muted' },
    { label: 'Siguiente lanzamiento', value: stats.next_run_at ? new Date(stats.next_run_at).toLocaleString('es-ES') : '—', detail: 'Próxima tarea prevista', tone: 'info' },
    { label: 'Eventos definidos', value: String(stats.event_task_count || 0), detail: stats.last_event_key ? `Último: ${stats.last_event_key}` : 'Sin disparos recientes', tone: 'warn' },
  ];
  els.schedulerStatusCards.innerHTML = cards.map((card) => `
    <article class="status-card status-card--${escapeHtml(card.tone)}">
      <span class="status-label">${escapeHtml(card.label)}</span>
      <strong>${escapeHtml(card.value)}</strong>
      <small>${escapeHtml(card.detail)}</small>
    </article>`).join('');
}

function filteredSchedulerTasks() {
  const category = els.schedulerCategoryFilterSelect?.value || '';
  const subcategory = els.schedulerSubcategoryFilterSelect?.value || '';
  return schedulerTasks().filter((item) => {
    if (category && String(item.category || '') !== category) return false;
    if (subcategory && String(item.subcategory || '') !== subcategory) return false;
    return true;
  });
}

function schedulerStatusChip(task) {
  const status = String(task.last_status || 'idle');
  if (status === 'success') return '<span class="scheduler-chip ok">OK</span>';
  if (status === 'error') return '<span class="scheduler-chip err">ERROR</span>';
  if (status === 'running') return '<span class="scheduler-chip warn">RUNNING</span>';
  if (status === 'skipped') return '<span class="scheduler-chip warn">SKIPPED</span>';
  return '<span class="scheduler-chip">IDLE</span>';
}

function renderSchedulerTaskList() {
  populateSchedulerFilters();
  if (!els.schedulerTasksList) return;
  const items = filteredSchedulerTasks();
  if (!items.length) {
    els.schedulerTasksList.innerHTML = '<div class="docker-empty-state">No hay tareas con el filtro actual.</div>';
    return;
  }
  els.schedulerTasksList.innerHTML = items.map((task) => {
    const selected = task.id === selectedSchedulerTaskId ? 'is-selected' : '';
    const scopeLabel = task.dispatch_scope === 'session' ? `Sesión: ${task.session_id}` : `Terminales: ${(task.target_ids || []).length || 0}`;
    const launchLabel = task.launch_type === 'docker_group' ? 'Grupo Docker' : (task.launch_type === 'script' ? 'Script' : 'Comando');
    const nextRun = task.next_run_at ? new Date(task.next_run_at).toLocaleString('es-ES') : '—';
    const lastRun = task.last_run_at ? new Date(task.last_run_at).toLocaleString('es-ES') : '—';
    return `
      <article class="scheduler-task-card ${selected}" data-scheduler-task-card="${escapeHtml(task.id)}">
        <div class="scheduler-task-head">
          <div>
            <div class="scheduler-task-title">${escapeHtml(task.name || 'Tarea')}</div>
            <div class="scheduler-task-tags">
              <span class="scheduler-chip">${task.enabled ? 'Activa' : 'Pausada'}</span>
              <span class="scheduler-chip">${escapeHtml(task.category || 'General')}</span>
              <span class="scheduler-chip">${escapeHtml(task.subcategory || 'General')}</span>
              <span class="scheduler-chip">${escapeHtml(launchLabel)}</span>
              ${schedulerStatusChip(task)}
            </div>
          </div>
          <div class="scheduler-task-actions">
            <button type="button" class="scheduler-mini-btn" data-scheduler-action="run" data-scheduler-task="${escapeHtml(task.id)}">Lanzar</button>
            <button type="button" class="scheduler-mini-btn ${task.enabled ? '' : 'danger'}" data-scheduler-action="toggle" data-scheduler-task="${escapeHtml(task.id)}">${task.enabled ? 'Pausar' : 'Activar'}</button>
          </div>
        </div>
        <div class="scheduler-task-meta">
          <span><b>Destino:</b> ${escapeHtml(scopeLabel)}</span>
          <span><b>Horario:</b> ${escapeHtml(String(task.schedule_type || 'once'))}</span>
          <span><b>Próxima:</b> ${escapeHtml(nextRun)}</span>
          <span><b>Última:</b> ${escapeHtml(lastRun)}</span>
        </div>
      </article>`;
  }).join('');
  els.schedulerTasksList.querySelectorAll('[data-scheduler-task-card]').forEach((card) => {
    card.addEventListener('click', (event) => {
      if (event.target.closest('[data-scheduler-action]')) return;
      selectedSchedulerTaskId = card.dataset.schedulerTaskCard || '';
      renderSchedulerTaskList();
      renderSchedulerEditor();
    });
  });
  els.schedulerTasksList.querySelectorAll('[data-scheduler-action="run"]').forEach((button) => button.addEventListener('click', async (event) => {
    event.stopPropagation();
    try {
      const response = await fetchJson('/api/scheduler/run-now', { method: 'POST', body: JSON.stringify({ task_id: button.dataset.schedulerTask || '' }) });
      runtimeConfig = response.config;
      ensureScriptsArray();
      ensureDockerStore();
      ensureSchedulerStore();
      setSchedulerMessage(response.message || 'Tarea lanzada.');
      renderSchedulerStatusCards();
      renderSchedulerTaskList();
      renderSchedulerLogTabs();
    } catch (error) { setSchedulerMessage(error.message || 'No se pudo lanzar la tarea.'); }
  }));
  els.schedulerTasksList.querySelectorAll('[data-scheduler-action="toggle"]').forEach((button) => button.addEventListener('click', (event) => {
    event.stopPropagation();
    const task = schedulerTasks().find((item) => item.id === (button.dataset.schedulerTask || ''));
    if (!task) return;
    task.enabled = !task.enabled;
    renderSchedulerTaskList();
    renderSchedulerEditor();
  }));
}

function renderSchedulerEditor() {
  const task = currentSchedulerTask();
  const catalog = schedulerCatalog();
  const sessions = catalog.sessions || [];
  const targets = catalog.targets_by_session?.[task.session_id] || [];
  const scripts = catalog.script_options || [];
  const dockerGroups = catalog.docker_group_options || [];
  const targetChecklist = targets.length ? targets.map((target) => `
    <label class="scheduler-target-line">
      <input type="checkbox" data-scheduler-target="${escapeHtml(target.id)}" ${(task.target_ids || []).includes(target.id) ? 'checked' : ''}>
      <span>
        <span>${escapeHtml(target.label || target.id)}</span>
        <small>${escapeHtml(target.connection_scope || 'terminal')} · ${escapeHtml(target.auth_type || 'none')}</small>
      </span>
    </label>`).join('') : '<div class="credential-note">No hay terminales disponibles en esta sesión.</div>';
  const weeklyChecks = [0,1,2,3,4,5,6].map((day) => {
    const labels = ['L','M','X','J','V','S','D'];
    return `<label class="check-field"><input type="checkbox" data-scheduler-weekday="${day}" ${(task.weekly_days || []).includes(day) ? 'checked' : ''}><span>${labels[day]}</span></label>`;
  }).join('');
  els.schedulerEditor.innerHTML = `
    <div class="scheduler-editor-grid">
      <label class="field"><span>Nombre</span><input id="schedulerTaskNameInput" type="text" value="${escapeHtml(task.name || '')}"></label>
      <label class="check-field"><input id="schedulerTaskEnabledInput" type="checkbox" ${task.enabled ? 'checked' : ''}><span>Tarea activa</span></label>
      <label class="field"><span>Categoría</span><input id="schedulerTaskCategoryInput" type="text" value="${escapeHtml(task.category || 'General')}"></label>
      <label class="field"><span>Subcategoría</span><input id="schedulerTaskSubcategoryInput" type="text" value="${escapeHtml(task.subcategory || 'General')}"></label>
      <label class="field full-row"><span>Descripción</span><textarea id="schedulerTaskDescriptionInput" rows="3" placeholder="Opcional">${escapeHtml(task.description || '')}</textarea></label>
      <label class="field"><span>Ámbito</span><select id="schedulerDispatchScopeSelect"><option value="terminal" ${task.dispatch_scope === 'terminal' ? 'selected' : ''}>Una o varias terminales</option><option value="session" ${task.dispatch_scope === 'session' ? 'selected' : ''}>Toda la sesión</option></select></label>
      <label class="field"><span>Sesión</span><select id="schedulerSessionSelect">${sessions.map((session) => `<option value="${escapeHtml(session.id)}" ${session.id === task.session_id ? 'selected' : ''}>${escapeHtml(session.name)}</option>`).join('')}</select></label>
      <div class="field full-row ${task.dispatch_scope === 'session' ? 'hidden' : ''}" id="schedulerTargetWrap"><span>Terminales destino</span><div class="scheduler-target-list-shell"><div class="scheduler-target-list">${targetChecklist}</div></div></div>
      <label class="field"><span>Qué lanzar</span><select id="schedulerLaunchTypeSelect"><option value="command" ${task.launch_type === 'command' ? 'selected' : ''}>Comando</option><option value="script" ${task.launch_type === 'script' ? 'selected' : ''}>Script</option><option value="docker_group" ${task.launch_type === 'docker_group' ? 'selected' : ''}>Grupo Docker</option></select></label>
      <label class="field ${task.launch_type !== 'script' ? 'hidden' : ''}" id="schedulerScriptSelectWrap"><span>Script</span><select id="schedulerScriptSelect">${scripts.map((script) => `<option value="${escapeHtml(script.id)}" ${script.id === task.script_id ? 'selected' : ''}>${escapeHtml(script.name)} · ${escapeHtml(script.category || 'General')}</option>`).join('')}</select></label>
      <label class="field ${task.launch_type !== 'docker_group' ? 'hidden' : ''}" id="schedulerDockerGroupWrap"><span>Grupo Docker</span><select id="schedulerDockerGroupSelect">${dockerGroups.map((group) => `<option value="${escapeHtml(group.id)}" ${group.id === task.docker_group_id ? 'selected' : ''}>${escapeHtml(group.name)}</option>`).join('')}</select></label>
      <label class="field full-row ${task.launch_type !== 'command' ? 'hidden' : ''}" id="schedulerCommandWrap"><span>Comando</span><textarea id="schedulerCommandTextInput" rows="4" placeholder="Ej. python script.py --flag">${escapeHtml(task.command_text || '')}</textarea></label>
      <label class="field"><span>Cuándo</span><select id="schedulerScheduleTypeSelect"><option value="once" ${task.schedule_type === 'once' ? 'selected' : ''}>Una vez a una hora</option><option value="delay" ${task.schedule_type === 'delay' ? 'selected' : ''}>Dentro de X minutos</option><option value="interval" ${task.schedule_type === 'interval' ? 'selected' : ''}>Periódica cada X minutos</option><option value="daily" ${task.schedule_type === 'daily' ? 'selected' : ''}>Diaria</option><option value="weekly" ${task.schedule_type === 'weekly' ? 'selected' : ''}>Semanal</option><option value="event" ${task.schedule_type === 'event' ? 'selected' : ''}>Por evento</option></select></label>
      <div class="field ${task.schedule_type !== 'once' ? 'hidden' : ''}" id="schedulerRunAtWrap"><span>Fecha / hora</span><input id="schedulerRunAtInput" type="datetime-local" value="${escapeHtml(String(task.run_at || '').slice(0,16))}"></div>
      <div class="field ${task.schedule_type !== 'delay' ? 'hidden' : ''}" id="schedulerDelayWrap"><span>Retraso (minutos)</span><input id="schedulerDelayMinutesInput" type="number" min="0" step="1" value="${Number(task.delay_minutes || 15)}"></div>
      <div class="field ${task.schedule_type !== 'interval' ? 'hidden' : ''}" id="schedulerIntervalWrap"><span>Intervalo (minutos)</span><input id="schedulerIntervalMinutesInput" type="number" min="1" step="1" value="${Number(task.interval_minutes || 60)}"></div>
      <div class="field ${task.schedule_type !== 'daily' ? 'hidden' : ''}" id="schedulerDailyWrap"><span>Hora diaria</span><input id="schedulerDailyTimeInput" type="time" value="${escapeHtml(task.daily_time || '08:00')}"></div>
      <div class="field full-row ${task.schedule_type !== 'weekly' ? 'hidden' : ''}" id="schedulerWeeklyWrap"><span>Semanal</span><div class="scheduler-schedule-grid"><label class="field"><span>Hora</span><input id="schedulerWeeklyTimeInput" type="time" value="${escapeHtml(task.weekly_time || '08:00')}"></label><div class="field full-row"><span>Días</span><div class="scheduler-inline-checks">${weeklyChecks}</div></div></div></div>
      <label class="field ${task.schedule_type !== 'event' ? 'hidden' : ''}" id="schedulerEventWrap"><span>Clave de evento</span><input id="schedulerTaskEventKeyInput" type="text" value="${escapeHtml(task.event_key || '')}" placeholder="Ej. post-deploy"></label>
      <label class="field"><span>Timeout (segundos)</span><input id="schedulerTimeoutInput" type="number" min="0" step="1" value="${Number(task.timeout_seconds || 0)}"></label>
      <div class="field"><span>Opciones</span><div class="scheduler-inline-checks"><label class="check-field"><input id="schedulerOverlapInput" type="checkbox" ${task.allow_overlap ? 'checked' : ''}><span>Permitir solape</span></label><label class="check-field"><input id="schedulerKeepTabInput" type="checkbox" ${task.keep_log_tab_open ? 'checked' : ''}><span>Dejar pestaña abierta</span></label></div></div>
    </div>
    <div class="scheduler-editor-actions">
      <button type="button" class="config-action-btn" id="schedulerEditorRunBtn">Lanzar ahora</button>
      <button type="button" class="config-action-btn danger-btn" id="schedulerDeleteTaskBtn">Eliminar tarea</button>
    </div>`;

  const sync = (rerender = false) => {
    task.name = els.schedulerEditor.querySelector('#schedulerTaskNameInput')?.value || task.name;
    task.enabled = !!els.schedulerEditor.querySelector('#schedulerTaskEnabledInput')?.checked;
    task.category = els.schedulerEditor.querySelector('#schedulerTaskCategoryInput')?.value || 'General';
    task.subcategory = els.schedulerEditor.querySelector('#schedulerTaskSubcategoryInput')?.value || 'General';
    task.description = els.schedulerEditor.querySelector('#schedulerTaskDescriptionInput')?.value || '';
    task.dispatch_scope = els.schedulerEditor.querySelector('#schedulerDispatchScopeSelect')?.value || 'terminal';
    task.session_id = els.schedulerEditor.querySelector('#schedulerSessionSelect')?.value || task.session_id;
    task.target_ids = [...els.schedulerEditor.querySelectorAll('[data-scheduler-target]:checked')].map((input) => input.dataset.schedulerTarget || '');
    task.launch_type = els.schedulerEditor.querySelector('#schedulerLaunchTypeSelect')?.value || 'command';
    task.script_id = els.schedulerEditor.querySelector('#schedulerScriptSelect')?.value || '';
    task.docker_group_id = els.schedulerEditor.querySelector('#schedulerDockerGroupSelect')?.value || '';
    task.command_text = els.schedulerEditor.querySelector('#schedulerCommandTextInput')?.value || '';
    task.schedule_type = els.schedulerEditor.querySelector('#schedulerScheduleTypeSelect')?.value || 'once';
    task.run_at = els.schedulerEditor.querySelector('#schedulerRunAtInput')?.value || '';
    task.delay_minutes = Number(els.schedulerEditor.querySelector('#schedulerDelayMinutesInput')?.value || task.delay_minutes || 15);
    task.interval_minutes = Number(els.schedulerEditor.querySelector('#schedulerIntervalMinutesInput')?.value || task.interval_minutes || 60);
    task.daily_time = els.schedulerEditor.querySelector('#schedulerDailyTimeInput')?.value || task.daily_time || '08:00';
    task.weekly_time = els.schedulerEditor.querySelector('#schedulerWeeklyTimeInput')?.value || task.weekly_time || '08:00';
    task.weekly_days = [...els.schedulerEditor.querySelectorAll('[data-scheduler-weekday]:checked')].map((input) => Number(input.dataset.schedulerWeekday || 0));
    task.event_key = els.schedulerEditor.querySelector('#schedulerTaskEventKeyInput')?.value || '';
    task.timeout_seconds = Number(els.schedulerEditor.querySelector('#schedulerTimeoutInput')?.value || 0);
    task.allow_overlap = !!els.schedulerEditor.querySelector('#schedulerOverlapInput')?.checked;
    task.keep_log_tab_open = !!els.schedulerEditor.querySelector('#schedulerKeepTabInput')?.checked;
    renderSchedulerTaskList();
    if (rerender) renderSchedulerEditor();
  };

  ['#schedulerTaskNameInput','#schedulerTaskCategoryInput','#schedulerTaskSubcategoryInput','#schedulerTaskDescriptionInput','#schedulerCommandTextInput','#schedulerRunAtInput','#schedulerDelayMinutesInput','#schedulerIntervalMinutesInput','#schedulerDailyTimeInput','#schedulerWeeklyTimeInput','#schedulerTaskEventKeyInput','#schedulerTimeoutInput'].forEach((selector) => els.schedulerEditor.querySelector(selector)?.addEventListener('input', () => sync(false)));
  ['#schedulerTaskEnabledInput','#schedulerOverlapInput','#schedulerKeepTabInput'].forEach((selector) => els.schedulerEditor.querySelector(selector)?.addEventListener('change', () => sync(false)));
  ['#schedulerDispatchScopeSelect','#schedulerSessionSelect','#schedulerLaunchTypeSelect','#schedulerScheduleTypeSelect','#schedulerScriptSelect','#schedulerDockerGroupSelect'].forEach((selector) => els.schedulerEditor.querySelector(selector)?.addEventListener('change', () => sync(true)));
  els.schedulerEditor.querySelectorAll('[data-scheduler-target]').forEach((input) => input.addEventListener('change', () => sync(false)));
  els.schedulerEditor.querySelectorAll('[data-scheduler-weekday]').forEach((input) => input.addEventListener('change', () => sync(false)));
  els.schedulerEditor.querySelector('#schedulerEditorRunBtn')?.addEventListener('click', async () => {
    try {
      const response = await fetchJson('/api/scheduler/run-now', { method: 'POST', body: JSON.stringify({ task_id: task.id }) });
      runtimeConfig = response.config;
      ensureScriptsArray();
      ensureDockerStore();
      ensureSchedulerStore();
      setSchedulerMessage(response.message || 'Tarea lanzada.');
      renderSchedulerStatusCards();
      renderSchedulerTaskList();
      renderSchedulerLogTabs();
    } catch (error) { setSchedulerMessage(error.message || 'No se pudo lanzar la tarea.'); }
  });
  els.schedulerEditor.querySelector('#schedulerDeleteTaskBtn')?.addEventListener('click', () => {
    runtimeConfig.scheduler_management.tasks = schedulerTasks().filter((item) => item.id !== task.id);
    selectedSchedulerTaskId = runtimeConfig.scheduler_management.tasks[0]?.id || '';
    renderSchedulerTaskList();
    renderSchedulerEditor();
  });
}

function renderSchedulerLogTabs() {
  if (!els.schedulerLogTabs) return;
  const tabs = schedulerLogTabs();
  if (!tabs.length) {
    els.schedulerLogTabs.innerHTML = '<div class="credential-note">Todavía no hay pestañas de log.</div>';
    return;
  }
  if (!tabs.some((item) => item.id === selectedSchedulerLogTabId)) selectedSchedulerLogTabId = tabs[0].id;
  els.schedulerLogTabs.innerHTML = tabs.map((tab) => `
    <button type="button" class="scheduler-log-tab ${tab.id === selectedSchedulerLogTabId ? 'is-active' : ''} ${tab.is_open ? '' : 'is-closed'}" data-scheduler-log-tab="${escapeHtml(tab.id)}">
      <span>${escapeHtml(tab.title || tab.id)}</span>
      <small>${escapeHtml(tab.subtitle || '')}${tab.running_count ? ` · ${tab.running_count} running` : ''}</small>
    </button>`).join('');
  const current = tabs.find((item) => item.id === selectedSchedulerLogTabId) || tabs[0];
  if (els.schedulerLogMeta) els.schedulerLogMeta.textContent = current ? `${current.title} · ${current.subtitle || ''}` : 'Selecciona una pestaña para ver su salida.';
  els.schedulerLogTabs.querySelectorAll('[data-scheduler-log-tab]').forEach((button) => button.addEventListener('click', () => {
    selectedSchedulerLogTabId = button.dataset.schedulerLogTab || 'scheduler-system';
    loadSchedulerLogTab(selectedSchedulerLogTabId, { reset: true }).catch((error) => setSchedulerMessage(error.message || 'No se pudieron cargar los logs.'));
    renderSchedulerLogTabs();
  }));
}

function schedulerLineClass(line = '') {
  const text = String(line || '').toUpperCase();
  if (text.includes('[ERR]') || text.includes('[ERROR]')) return 'log-err';
  if (text.includes('[OK]')) return 'log-ok';
  if (text.includes('[PROC]')) return 'log-proc';
  if (text.includes('[WARN]') || text.includes('[SKIPPED]')) return 'log-warn';
  return '';
}

async function loadSchedulerLogTab(tabId, options = {}) {
  if (!tabId) return;
  const reset = !!options.reset;
  if (reset) {
    schedulerLogLastSeq = 0;
    if (els.schedulerLogConsole) els.schedulerLogConsole.innerHTML = '';
  }
  const response = await fetchJson(`/api/scheduler/logs?tab_id=${encodeURIComponent(tabId)}&after_seq=${encodeURIComponent(schedulerLogLastSeq || 0)}`);
  const lines = response.lines || [];
  if (els.schedulerLogConsole && lines.length) {
    const html = lines.map((entry) => `<span class="${schedulerLineClass(entry.line)}">${escapeHtml(entry.line || '')}</span>`).join('\n') + '\n';
    els.schedulerLogConsole.insertAdjacentHTML('beforeend', html);
    els.schedulerLogConsole.scrollTop = els.schedulerLogConsole.scrollHeight;
  }
  schedulerLogLastSeq = Number(response.last_seq || schedulerLogLastSeq || 0);
}

async function refreshSchedulerState(options = {}) {
  const silent = !!options.silent;
  try {
    const response = await fetchJson('/api/scheduler/state');
    runtimeConfig = response.config;
    ensureScriptsArray();
    ensureDockerStore();
    ensureSchedulerStore();
    renderSchedulerStatusCards();
    renderSchedulerTaskList();
    renderSchedulerEditor();
    renderSchedulerLogTabs();
    if (!silent) setSchedulerMessage('Scheduler actualizado.');
  } catch (error) {
    if (!silent) setSchedulerMessage(error.message || 'No se pudo refrescar Scheduler.');
    throw error;
  }
}

async function saveSchedulerTasks() {
  const response = await fetchJson('/api/scheduler/save', { method: 'POST', body: JSON.stringify({ tasks: schedulerTasks() }) });
  runtimeConfig = response.config;
  ensureScriptsArray();
  ensureDockerStore();
  ensureSchedulerStore();
  setSchedulerMessage('Tareas programadas guardadas.');
  renderSchedulerStatusCards();
  renderSchedulerTaskList();
  renderSchedulerEditor();
  renderSchedulerLogTabs();
}

async function fireSchedulerEvent() {
  const eventKey = (els.schedulerEventKeyInput?.value || '').trim();
  if (!eventKey) {
    setSchedulerMessage('Indica una clave de evento.');
    return;
  }
  const response = await fetchJson('/api/scheduler/event/fire', { method: 'POST', body: JSON.stringify({ event_key: eventKey }) });
  runtimeConfig = response.config;
  ensureScriptsArray();
  ensureDockerStore();
  ensureSchedulerStore();
  setSchedulerMessage(response.message || 'Evento disparado.');
  renderSchedulerStatusCards();
  renderSchedulerTaskList();
  renderSchedulerLogTabs();
}

function stopSchedulerPolling() {
  if (schedulerStatePollTimer) window.clearInterval(schedulerStatePollTimer);
  if (schedulerLogPollTimer) window.clearInterval(schedulerLogPollTimer);
  schedulerStatePollTimer = null;
  schedulerLogPollTimer = null;
}

function startSchedulerPolling() {
  stopSchedulerPolling();
  schedulerStatePollTimer = window.setInterval(() => {
    if (els.schedulerView?.classList.contains('hidden')) return;
    refreshSchedulerState({ silent: true }).catch(() => {});
  }, 2500);
  schedulerLogPollTimer = window.setInterval(() => {
    if (els.schedulerView?.classList.contains('hidden')) return;
    loadSchedulerLogTab(selectedSchedulerLogTabId, { reset: false }).catch(() => {});
  }, 900);
}

function showSchedulerView() {
  if (!userCan('manage_scheduler')) return;
  els.mainView.classList.add('hidden');
  els.configView.classList.add('hidden');
  els.adminView.classList.add('hidden');
  els.scriptsView.classList.add('hidden');
  els.dockerView.classList.add('hidden');
  els.explorerView.classList.add('hidden');
  els.schedulerView.classList.remove('hidden');
  refreshSchedulerState({ silent: true }).then(() => loadSchedulerLogTab(selectedSchedulerLogTabId || 'scheduler-system', { reset: true })).catch((error) => setSchedulerMessage(error.message || 'No se pudo abrir Scheduler.'));
  startSchedulerPolling();
  applyFeatureVisibility();
}


function showExplorerView() {
  if (!userCan('use_explorer')) return;
  els.mainView.classList.add('hidden');
  els.configView.classList.add('hidden');
  els.adminView.classList.add('hidden');
  els.scriptsView.classList.add('hidden');
  els.dockerView.classList.add('hidden');
  els.schedulerView.classList.add('hidden');
  stopSchedulerPolling();
  els.explorerView.classList.remove('hidden');
  initExplorerSplitResize();
  loadExplorerPath(explorerState.currentPath || runtimeConfig?.workspace_dir || '').catch((error) => setExplorerMessage(error.message || 'No se pudo abrir Explorer.'));
  applyFeatureVisibility();
}

function bindStaticEvents() {
  if (staticEventsBound) return;
  bindAccordionEvents();
  staticEventsBound = true;
  els.loginForm?.addEventListener('submit', handleLogin);
  els.logoutBtn?.addEventListener('click', handleLogout);
  els.configBtn?.addEventListener('click', showConfigView);
  els.adminPageBtn?.addEventListener('click', showAdministrationView);
  els.scriptsPageBtn?.addEventListener('click', showScriptsView);
  els.dockerPageBtn?.addEventListener('click', showDockerView);
  els.schedulerPageBtn?.addEventListener('click', showSchedulerView);
  els.explorerPageBtn?.addEventListener('click', showExplorerView);
  els.backBtn?.addEventListener('click', showMainView);
}

function bindEvents() {
  if (appEventsBound) return;
  appEventsBound = true;

  els.newTabScopeSelect.addEventListener('change', async () => {
    if (els.newTabScopeSelect.value === 'docker') {
      try { await refreshDockerOverview({ silent: true }); } catch {}
    }
    updateNewTabTargetOptions();
    renderNewTabCredentialFields();
  });
  els.newTabAuthSelect.addEventListener('change', () => {
    updateNewTabTargetOptions();
    renderNewTabCredentialFields();
  });
  els.newTabTargetOsSelect.addEventListener('change', () => {
    updateNewTabTargetOptions();
    renderNewTabCredentialFields();
  });
  els.newTabTargetSelect.addEventListener('change', () => {
    syncNewTabNameWithTarget();
    renderNewTabCredentialFields();
  });
  els.newTabName.addEventListener('input', () => {
    if ((els.newTabName.value || '').trim() !== (els.newTabName.dataset.autoValue || '')) return;
    els.newTabName.dataset.autoValue = els.newTabName.value || '';
  });
  els.newTabBtn.addEventListener('click', createNewTabFromControls);

  els.restartBtn.addEventListener('click', () => connectActiveTab('restart'));
  els.clearBtn.addEventListener('click', () => { const tab = getActiveTab(); tab?.term.clear(); tab?.term.focus(); });
  els.copyBtn.addEventListener('click', copyActiveTab);
  els.pasteBtn.addEventListener('click', pasteIntoActiveTab);
  els.saveBtn.addEventListener('click', saveActiveTabOutput);
  els.downloadCwdZipBtn.addEventListener('click', downloadActiveTabCurrentPathZip);
  els.treePathBtn.addEventListener('click', printActiveTabPathTree);
  els.importDirNoOverwriteBtn.addEventListener('click', () => importDirectoryIntoActiveTab(false));
  els.importDirOverwriteBtn.addEventListener('click', () => importDirectoryIntoActiveTab(true));
  els.createAliasBtn.addEventListener('click', createAliasForActiveTab);
  els.aliasGroupFilterSelect?.addEventListener('change', () => {
    const tab = getActiveTab();
    if (!tab) return;
    tab.aliasGroupFilter = els.aliasGroupFilterSelect?.value || '';
    renderAliasPanel();
  });
  els.scriptCategoryFilterSelect?.addEventListener('change', () => {
    populateHomeScriptFilters();
    renderScriptsPanel();
  });
  els.scriptSubcategoryFilterSelect?.addEventListener('change', () => {
    renderScriptsPanel();
  });
  els.commandHistoryLimitInput.addEventListener('input', () => {
    runtimeConfig.ui.command_history_limit = Number(els.commandHistoryLimitInput.value || 50);
    applyHistoryLimitToAllTabs();
  });
  els.activeSessionSelect?.addEventListener('change', async () => {
    const response = await fetchJson('/api/session/select', { method: 'POST', body: JSON.stringify({ session_id: els.activeSessionSelect.value || 'default' }) });
    runtimeConfig = response.config;
    ensureScriptsArray();
    populateTopSessionSelectors();
    updateNewTabTargetOptions();
    syncNewTabNameWithTarget(true);
    renderNewTabCredentialFields();
    renderCredentialFields();
    renderScriptsPanel();
    if (!tabs.length) { didAutoOpenDefaultSessionTabs = false; autoOpenDefaultSessionTabs(); }
  });
  els.configActiveSessionSelect?.addEventListener('change', () => {
    runtimeConfig.active_session_id = els.configActiveSessionSelect.value || 'default';
    populateTopSessionSelectors();
  });
  els.configPresetSessionSelect?.addEventListener('change', () => {
    selectedConfigSessionId = els.configPresetSessionSelect.value || 'general';
    renderConfigPresets();
  });
  els.addSessionBtn?.addEventListener('click', () => {
    const name = String(els.newSessionNameInput?.value || '').trim();
    if (!name) { if (els.configMessage) els.configMessage.textContent = 'Escribe un nombre para la nueva sesión.'; return; }
    const nextId = name.toLowerCase().replace(/[^a-z0-9._-]+/g, '-').replace(/^-+|-+$/g, '') || uid('session');
    if (sessionItems().some((item) => item.id === nextId)) { if (els.configMessage) els.configMessage.textContent = 'Ya existe una sesión con ese identificador.'; return; }
    runtimeConfig.terminal_sessions = [...sessionItems(), { id: nextId, name }];
    if (els.newSessionNameInput) els.newSessionNameInput.value = '';
    populateTopSessionSelectors();
    if (els.configMessage) els.configMessage.textContent = `Sesión añadida: ${name}`;
  });
  els.removeSessionBtn?.addEventListener('click', () => {
    const sessionId = els.configActiveSessionSelect?.value || activeSessionId();
    if (!sessionId || sessionId === 'default') { if (els.configMessage) els.configMessage.textContent = 'La sesión principal no se puede eliminar.'; return; }
    runtimeConfig.terminal_sessions = sessionItems().filter((item) => item.id !== sessionId);
    if (runtimeConfig.session_terminal_overrides) delete runtimeConfig.session_terminal_overrides[sessionId];
    if (runtimeConfig.active_session_id === sessionId) runtimeConfig.active_session_id = 'default';
    if (selectedConfigSessionId === sessionId) selectedConfigSessionId = 'general';
    populateTopSessionSelectors();
    renderConfigPresets();
    if (els.configMessage) els.configMessage.textContent = 'Sesión eliminada.';
  });

  els.terminalPresetSelect.addEventListener('change', () => {
    selectedPresetIndex = Number(els.terminalPresetSelect.value || 0);
    renderConfigPresets();
  });
  els.addLocalPresetBtn.addEventListener('click', () => {
    const hostOs = runtimeConfig.host_os || 'windows';
    const shellId = firstShellIdFor('local', hostOs) || '';
    const localCount = (runtimeConfig.terminal_presets || []).filter((item) => item.scope === 'local' && !item.detected_local).length + 1;
    runtimeConfig.terminal_presets.push({ id: uid('preset'), name: `Terminal local ${localCount}`, scope: 'local', auth_type: 'none', target_os: hostOs, shell_family: shellId, host: '', port: 22, username: '', private_key_path: '', strict_host_key: true, startup_command: '', command_file_content: '', command_source: 'text', launch_command: shellId, detected_local: false, editable_scope: true, editable_target_os: false, editable_remove: true, open_by_default: false });
    selectedPresetIndex = runtimeConfig.terminal_presets.length - 1;
    renderConfigPresets();
  });
  els.addRemotePresetBtn.addEventListener('click', () => {
    const authType = els.newRemotePresetAuthType.value || 'password';
    const remoteCount = (runtimeConfig.terminal_presets || []).filter((item) => item.scope === 'remote').length + 1;
    runtimeConfig.terminal_presets.push({ id: uid('preset'), name: `Terminal remota ${remoteCount}`, scope: 'remote', auth_type: authType, target_os: 'linux', shell_family: firstShellIdFor('remote', 'linux') || '', host: '', port: 22, username: '', private_key_path: '', strict_host_key: true, startup_command: '', command_file_content: '', command_source: 'text', detected_local: false, editable_scope: true, editable_target_os: true, editable_remove: true, open_by_default: false });
    selectedPresetIndex = runtimeConfig.terminal_presets.length - 1;
    renderConfigPresets();
  });
  els.saveConfigBtn.addEventListener('click', saveGlobalConfig);
  els.scriptConfigCategorySelect?.addEventListener('change', () => { populateScriptSelector(); renderScriptEditor(); });
  els.scriptSelect?.addEventListener('change', () => { selectedScriptIndex = Number(els.scriptSelect.value || 0); renderScriptEditor(); });
  els.addScriptBtn?.addEventListener('click', () => { ensureScriptsArray(); runtimeConfig.app_scripts.push(emptyScriptTemplate()); selectedScriptIndex = runtimeConfig.app_scripts.length - 1; renderScriptEditor(); });
  els.removeScriptBtn?.addEventListener('click', () => { ensureScriptsArray(); if (!runtimeConfig.app_scripts.length) return; runtimeConfig.app_scripts.splice(selectedScriptIndex, 1); if (selectedScriptIndex >= runtimeConfig.app_scripts.length) selectedScriptIndex = Math.max(0, runtimeConfig.app_scripts.length - 1); renderScriptEditor(); renderScriptsPanel(); });
  els.saveScriptsBtn?.addEventListener('click', saveScriptsConfig);
  els.dockerRefreshBtn?.addEventListener('click', () => { refreshDockerOverview({ silent: false }).catch(() => {}); });
  els.dockerSearchInput?.addEventListener('input', renderDockerContainers);
  els.dockerStateFilterSelect?.addEventListener('change', renderDockerContainers);
  els.dockerShowStoppedCheckbox?.addEventListener('change', renderDockerContainers);
  els.dockerGroupSelect?.addEventListener('change', () => { selectedDockerGroupId = els.dockerGroupSelect.value || ''; syncDockerGroupFormFromState(); });
  els.dockerNewGroupBtn?.addEventListener('click', () => { ensureDockerStore(); syncDockerGroupStateFromForm(); dockerDraftGroup = newEmptyDockerGroup(); selectedDockerGroupId = ''; syncDockerGroupFormFromState(); setDockerMessage('Nuevo grupo Docker preparado.'); });
  els.dockerDeleteGroupBtn?.addEventListener('click', () => {
    ensureDockerStore();
    if (!selectedDockerGroupId) {
      dockerDraftGroup = newEmptyDockerGroup();
      syncDockerGroupFormFromState();
      setDockerMessage('Borrador descartado.');
      return;
    }
    runtimeConfig.docker_management.groups = dockerGroups().filter((item) => item.id !== selectedDockerGroupId);
    selectedDockerGroupId = '';
    syncDockerGroupFormFromState();
    setDockerMessage('Grupo eliminado de la vista. Guarda para persistir.');
  });
  els.dockerGroupNameInput?.addEventListener('input', () => { syncDockerGroupStateFromForm(); populateDockerGroupSelector(); renderDockerGroupsList(); });
  els.dockerGroupDescriptionInput?.addEventListener('input', () => { syncDockerGroupStateFromForm(); renderDockerGroupsList(); });
  els.dockerGroupDefaultModeSelect?.addEventListener('change', () => { syncDockerGroupStateFromForm(); renderDockerGroupsList(); });
  els.dockerSaveGroupsBtn?.addEventListener('click', () => { saveDockerGroups().catch((error) => setDockerMessage(error.message || 'No se pudieron guardar los grupos Docker.')); });
  els.dockerGenerateScriptBtn?.addEventListener('click', () => { generateDockerGroupScript().catch((error) => setDockerMessage(error.message || 'No se pudo generar el script Docker.')); });

  els.adminAddUserBtn?.addEventListener('click', addAdministrationUser);
  els.adminRemoveUserBtn?.addEventListener('click', removeAdministrationUser);
  els.adminSaveBtn?.addEventListener('click', () => { saveAdministrationUsers().catch((error) => setAdminMessage(error.message || 'No se pudieron guardar los usuarios.')); });

  els.schedulerNewTaskBtn?.addEventListener('click', () => {
    ensureSchedulerStore();
    const task = newEmptySchedulerTask();
    runtimeConfig.scheduler_management.tasks = [...schedulerTasks(), task];
    selectedSchedulerTaskId = task.id;
    populateSchedulerFilters();
    renderSchedulerTaskList();
    renderSchedulerEditor();
    setSchedulerMessage('Nueva tarea preparada. Guarda para persistirla.');
  });
  els.schedulerSaveBtn?.addEventListener('click', () => { saveSchedulerTasks().catch((error) => setSchedulerMessage(error.message || 'No se pudieron guardar las tareas.')); });
  els.schedulerRefreshBtn?.addEventListener('click', () => { refreshSchedulerState({ silent: false }).catch((error) => setSchedulerMessage(error.message || 'No se pudo refrescar Scheduler.')); });
  els.schedulerCategoryFilterSelect?.addEventListener('change', () => { populateSchedulerFilters(); renderSchedulerTaskList(); });
  els.schedulerSubcategoryFilterSelect?.addEventListener('change', renderSchedulerTaskList);
  els.schedulerFireEventBtn?.addEventListener('click', () => { fireSchedulerEvent().catch((error) => setSchedulerMessage(error.message || 'No se pudo disparar el evento.')); });
  els.schedulerEventKeyInput?.addEventListener('keydown', (event) => { if (event.key === 'Enter') fireSchedulerEvent().catch((error) => setSchedulerMessage(error.message || 'No se pudo disparar el evento.')); });
  els.schedulerClearLogBtn?.addEventListener('click', () => { if (els.schedulerLogConsole) els.schedulerLogConsole.innerHTML = ''; schedulerLogLastSeq = 0; loadSchedulerLogTab(selectedSchedulerLogTabId || 'scheduler-system', { reset: true }).catch(() => {}); });

  els.explorerRefreshBtn?.addEventListener('click', () => { loadExplorerPath(explorerState.currentPath).catch((error) => setExplorerMessage(error.message || 'No se pudo refrescar.')); });
  els.explorerGoBtn?.addEventListener('click', () => { loadExplorerPath(els.explorerPathInput?.value || '').catch((error) => setExplorerMessage(error.message || 'Ruta inválida.')); });
  els.explorerPathInput?.addEventListener('keydown', (event) => { if (event.key === 'Enter') loadExplorerPath(els.explorerPathInput?.value || '').catch((error) => setExplorerMessage(error.message || 'Ruta inválida.')); });
  els.explorerFilterInput?.addEventListener('input', () => { explorerState.filter = els.explorerFilterInput.value || ''; renderExplorerList(); });
  els.explorerUpBtn?.addEventListener('click', () => { const parent = explorerState.breadcrumbs.length > 1 ? explorerState.breadcrumbs[explorerState.breadcrumbs.length - 2].path : ''; if (parent) loadExplorerPath(parent).catch((error) => setExplorerMessage(error.message || 'No se pudo subir de nivel.')); });
  els.explorerNewFolderBtn?.addEventListener('click', async () => { if (!explorerCanWriteCurrentDir()) { setExplorerMessage('Esta ruta está en modo solo lectura para este usuario.'); return; } const name = window.prompt('Nombre de la nueva carpeta'); if (!name) return; try { const response = await fetchJson('/api/explorer/mkdir', { method: 'POST', body: JSON.stringify({ path: explorerState.currentPath, name }) }); setExplorerMessage(response.message || 'Carpeta creada.'); await loadExplorerPath(explorerState.currentPath); } catch (error) { setExplorerMessage(error.message || 'No se pudo crear la carpeta.'); } });
  els.explorerPasteBtn?.addEventListener('click', () => { explorerPasteClipboard().catch((error) => setExplorerMessage(error.message || 'No se pudo pegar.')); });
  els.explorerSaveFileBtn?.addEventListener('click', () => { saveExplorerFile().catch((error) => setExplorerMessage(error.message || 'No se pudo guardar.')); });
  els.explorerDownloadBtn?.addEventListener('click', () => { const path = explorerState.openedFile?.path || explorerState.selectedPath || explorerState.currentPath; if (path) window.open(explorerDownloadUrl(path), '_blank'); });
  els.explorerSourceTabBtn?.addEventListener('click', () => { explorerState.renderedMode = 'source'; renderExplorerPreview(); });
  els.explorerRenderedTabBtn?.addEventListener('click', () => { explorerState.renderedMode = 'render'; renderExplorerPreview(); });
  els.explorerEditor?.addEventListener('input', refreshExplorerHighlight);
  els.explorerEditor?.addEventListener('scroll', refreshExplorerHighlight);
  els.explorerUploadInput?.addEventListener('change', () => { explorerUploadFiles(els.explorerUploadInput.files).catch((error) => setExplorerMessage(error.message || 'No se pudo subir.')).finally(() => { if (els.explorerUploadInput) els.explorerUploadInput.value = ''; }); });
  els.explorerDropZone?.addEventListener('click', () => { if (!explorerCanWriteCurrentDir()) { setExplorerMessage('Esta ruta está en modo solo lectura para este usuario.'); return; } els.explorerUploadInput?.click(); });
  ['dragenter','dragover'].forEach((eventName) => els.explorerDropZone?.addEventListener(eventName, (event) => { if (!explorerCanWriteCurrentDir()) return; event.preventDefault(); els.explorerDropZone.classList.add('is-dragover'); }));
  ['dragleave','drop'].forEach((eventName) => els.explorerDropZone?.addEventListener(eventName, (event) => { if (!explorerCanWriteCurrentDir() && eventName !== 'dragleave') return; event.preventDefault(); if (eventName === 'drop' && event.dataTransfer?.files?.length) explorerUploadFiles(event.dataTransfer.files).catch((error) => setExplorerMessage(error.message || 'No se pudo subir.')); els.explorerDropZone.classList.remove('is-dragover'); }));

  document.addEventListener('click', (event) => {
    if (tabContextMenu && !tabContextMenu.contains(event.target)) hideTabContextMenu();
    if (terminalContextMenu && !terminalContextMenu.contains(event.target)) hideTerminalContextMenu();
    if (explorerContextMenu && !explorerContextMenu.contains(event.target)) hideExplorerContextMenu();
  });
  document.addEventListener('contextmenu', (event) => {
    if (tabContextMenu && !event.target.closest('.tab-chip') && !(tabContextMenu.contains(event.target))) hideTabContextMenu();
    if (terminalContextMenu && !event.target.closest('.terminal-host') && !(terminalContextMenu.contains(event.target))) hideTerminalContextMenu();
    if (explorerContextMenu && !event.target.closest('.explorer-row') && !(explorerContextMenu.contains(event.target))) hideExplorerContextMenu();
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      hideTabContextMenu();
      hideTerminalContextMenu();
      hideExplorerContextMenu();
    }
  });

  window.addEventListener('resize', () => {
    const tab = getActiveTab();
    if (!tab) return;
    tab.fitAddon.fit();
    if (tab.socket && tab.socket.readyState === WebSocket.OPEN) tab.socket.send(JSON.stringify({ type: 'resize', cols: tab.term.cols, rows: tab.term.rows }));
  });
}

function autoOpenDefaultSessionTabs() {
  if (didAutoOpenDefaultSessionTabs) return;
  didAutoOpenDefaultSessionTabs = true;
  const defaults = (runtimeConfig?.targets || []).filter((target) => !!target.open_by_default);
  defaults.forEach((target) => {
    const tab = createTab({ title: target.label, targetId: target.id, scrollback: Number(runtimeConfig.ui.default_scrollback || 20000), credentials: {} });
    openSocketForTab(tab, 'start');
  });
}

async function loadBootstrap() {
  await reloadRuntimeConfig();
  if (els.loginUsername) els.loginUsername.value = runtimeConfig?.auth?.admin_username || els.loginUsername.value || '';
  ensureAuthenticatedUi();
  if (authStatus.authenticated || !(runtimeConfig?.auth?.login_required)) autoOpenDefaultSessionTabs();
}

bindStaticEvents();

bindEvents();

loadBootstrap().catch((error) => {
  console.error(error);
  els.terminalMeta.innerHTML = `<span class="meta-item"><span class="meta-key meta-key-0">Error:</span> ${escapeHtml(error.message)}</span>`;
});
})();
